---
import Layout from '../layouts/Layout.astro';
const canonical = 'https://yourdomain.com';
---

<Layout title="Nova Studio — Digital Studio for High-Performance Websites & UI" description="We craft premium websites, complex interactions, and bespoke digital experiences that elevate brands and drive results." canonical={canonical}>

  <!-- ==================== HERO ==================== -->
  <section id="hero" class="showcase-hero pb-10 pt-6 sm:pb-16 sm:pt-10">
    <div class="grid gap-6 sm:gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
      <div class="hero-copy">
        <p class="text-xs font-mono uppercase tracking-widest text-accent">[01 / DIGITAL STUDIO]</p>
        <h1 class="mt-4 sm:mt-5 max-w-3xl text-3xl font-semibold tracking-tight leading-[1.06] text-white sm:text-5xl lg:text-5xl xl:text-[4.35rem]">
          We build premium digital experiences that make your brand impossible to ignore.
        </h1>
        <p class="mt-4 sm:mt-5 max-w-2xl text-sm sm:text-lg tracking-tight text-zinc-300">
          We are a digital studio specializing in high-performance websites, complex UI interactions, and bespoke interfaces. Our work combines strategic clarity with luxury-tech execution — turning ambitious ideas into polished, conversion-ready products.
        </p>
        <div class="mt-5 sm:mt-8 flex flex-col gap-3 sm:gap-4 sm:flex-row">
          <a href="#services" class="inline-flex items-center justify-center rounded-full bg-accent px-5 py-3 sm:px-8 sm:py-4 text-sm sm:text-base font-semibold text-black shadow-[0_0_0_rgba(0,179,126,0.35)] transition-all duration-300 ease-out hover:shadow-[0_0_40px_rgba(0,179,126,0.28)]">Explore Our Services</a>
          <a href="#work" class="inline-flex items-center justify-center rounded-full border border-zinc-700 bg-[#111113] px-5 py-3 sm:px-8 sm:py-4 text-sm sm:text-base font-semibold text-zinc-200 transition-all duration-300 ease-out hover:border-zinc-600 hover:text-white">View Our Work</a>
        </div>

        <div class="mt-5 sm:mt-8 max-w-xl rounded-[2rem] border border-zinc-800/60 bg-[#141417] p-4 sm:p-5 shadow-soft">
          <article class="grid gap-3 sm:gap-4">
            <div class="flex flex-col gap-2 sm:gap-3 sm:flex-row sm:items-center sm:justify-between">
              <span class="rounded-full bg-accent/10 px-3 py-1 text-xs uppercase tracking-[0.32em] text-accent">What we deliver</span>
              <p class="text-xs sm:text-sm text-zinc-400">Strategy, UI design, development, and launch — crafted as one seamless experience.</p>
            </div>
            <div class="grid gap-3 sm:gap-4 sm:grid-cols-3">
              <div class="rounded-3xl bg-[#0f0f12] p-4 sm:p-5 text-center">
                <span class="block text-xs sm:text-sm uppercase tracking-[0.28em] text-zinc-500">Performance</span>
                <strong class="mt-2 sm:mt-3 block text-2xl sm:text-3xl font-semibold text-white">Blazing</strong>
              </div>
              <div class="rounded-3xl bg-[#0f0f12] p-4 sm:p-5 text-center">
                <span class="block text-xs sm:text-sm uppercase tracking-[0.28em] text-zinc-500">Design</span>
                <strong class="mt-2 sm:mt-3 block text-2xl sm:text-3xl font-semibold text-white">Premium</strong>
              </div>
              <div class="rounded-3xl bg-[#0f0f12] p-4 sm:p-5 text-center">
                <span class="block text-xs sm:text-sm uppercase tracking-[0.28em] text-zinc-500">SEO</span>
                <strong class="mt-2 sm:mt-3 block text-2xl sm:text-3xl font-semibold text-white">Built-in</strong>
              </div>
            </div>
          </article>
        </div>
      </div>

      <div class="hero-visual" aria-label="Interactive 3D mobile website preview">
        <div class="iphone-scene" data-iphone-scene data-model-src="/assets/models/iphone.gltf">
          <canvas aria-hidden="true"></canvas>
          <div class="iphone-fallback">
            <div class="fallback-phone">
              <span></span>
              <strong>1.8s</strong>
              <p>Fast, clear, and ready.</p>
            </div>
          </div>
        </div>
        <div class="hero-visual-caption">
          <span>Interactive preview</span>
          <strong>Every interface we build is designed for mobile-first audiences</strong>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== POSITIONING / APPROACH ==================== -->
  <section id="work" class="space-y-8 sm:space-y-12 pb-16 sm:pb-20">
    <div class="grid gap-6 lg:grid-cols-[0.85fr_1.15fr] lg:items-end">
      <div class="space-y-3 sm:space-y-4">
        <p class="text-xs font-mono uppercase tracking-widest text-zinc-500">[02 / OUR APPROACH]</p>
        <h2 class="text-2xl sm:text-3xl font-semibold tracking-tight text-white sm:text-4xl">We don't just build websites. We build digital experiences that earn trust and drive action.</h2>
      </div>
        <p class="max-w-3xl text-sm sm:text-base leading-6 sm:leading-8 text-zinc-400">Every project we take on starts with a simple question: what does the audience need to feel and understand? From there, we organize content around clarity, design around intention, and develop around performance. The result is a digital presence that feels deliberate, credible, and unmistakably premium.</p>
    </div>

    <div class="grid gap-4 sm:gap-6 lg:grid-cols-3">
      <article class="rounded-2xl bg-[#141417] border border-zinc-800/60 p-5 sm:p-8 transition-all duration-300 hover:border-zinc-700/80">
        <p class="text-xs font-mono uppercase tracking-widest text-zinc-500">Strategy</p>
        <h3 class="mt-3 sm:mt-4 text-xl sm:text-2xl font-semibold tracking-tight text-white">We clarify the message.</h3>
        <p class="mt-3 sm:mt-4 text-sm sm:text-base text-zinc-400">We refine the positioning, narrative, and structure so every visitor understands your value within seconds — not paragraphs.</p>
      </article>
      <article class="rounded-2xl bg-[#141417] border border-zinc-800/60 p-5 sm:p-8 transition-all duration-300 hover:border-zinc-700/80">
        <p class="text-xs font-mono uppercase tracking-widest text-zinc-500">Design</p>
        <h3 class="mt-3 sm:mt-4 text-xl sm:text-2xl font-semibold tracking-tight text-white">We craft the experience.</h3>
        <p class="mt-3 sm:mt-4 text-sm sm:text-base text-zinc-400">From the first scroll to the final CTA, every section is designed to guide, impress, and convert — without overwhelming.</p>
      </article>
      <article class="rounded-2xl bg-[#141417] border border-zinc-800/60 p-5 sm:p-8 transition-all duration-300 hover:border-zinc-700/80">
        <p class="text-xs font-mono uppercase tracking-widest text-zinc-500">Delivery</p>
        <h3 class="mt-3 sm:mt-4 text-xl sm:text-2xl font-semibold tracking-tight text-white">We launch with confidence.</h3>
        <p class="mt-3 sm:mt-4 text-sm sm:text-base text-zinc-400">Our builds are fast, responsive, and built to last — so your team can maintain and evolve the site long after launch.</p>
      </article>
    </div>
  </section>

  <!-- ==================== PORTFOLIO / CASE STUDIES ==================== -->
  <section class="space-y-8 sm:space-y-10 pb-16 sm:pb-20">
    <div class="grid gap-6 lg:grid-cols-[0.9fr_1fr] lg:items-end">
      <div class="space-y-3 sm:space-y-4">
        <p class="text-xs font-mono uppercase tracking-widest text-zinc-500">[03 / OUR PRODUCTIONS]</p>
        <h2 class="text-2xl sm:text-3xl font-semibold tracking-tight text-white sm:text-4xl">Case studies that showcase what we build.</h2>
      </div>
      <p class="max-w-3xl text-sm sm:text-base leading-6 sm:leading-8 text-zinc-400">Every project we deliver reflects our commitment to clarity, performance, and premium execution. Here is a selection of our recent work.</p>
    </div>

    <div class="grid grid-cols-1 gap-4 sm:gap-6 md:grid-cols-3">
      <article class="md:col-span-2 rounded-2xl bg-[#141417] border border-zinc-800/60 p-5 sm:p-8 transition-all duration-300 hover:border-zinc-700/80">
        <p class="text-xs font-mono uppercase tracking-widest text-accent">SaaS Dashboard</p>
        <h3 class="mt-3 sm:mt-4 text-xl sm:text-2xl font-semibold tracking-tight text-white">Nova Flow — enterprise analytics interface.</h3>
        <div class="mt-4 sm:mt-6 grid gap-4 text-zinc-400 sm:grid-cols-3">
          <div>
            <p class="font-semibold text-white">Our goal</p>
            <p class="mt-2 text-sm sm:text-base">Transform a complex data platform into an intuitive, visually compelling dashboard that users trust at first glance.</p>
          </div>
          <div>
            <p class="font-semibold text-white">Our solution</p>
            <p class="mt-2 text-sm sm:text-base">We designed a clean desktop and mobile experience with strong contrast, clear data hierarchy, and seamless navigation.</p>
          </div>
          <div>
            <p class="font-semibold text-white">Result</p>
            <p class="mt-2 text-sm sm:text-base">A sharper product presence that helps buyers evaluate with confidence — even under time pressure.</p>
          </div>
        </div>
        <figure class="mt-6 sm:mt-8 grid grid-cols-1 md:grid-cols-2 gap-4 sm:gap-6">
          <div class="relative aspect-[16/9] overflow-hidden rounded-3xl border border-zinc-800/60 bg-[radial-gradient(circle_at_30%_40%,rgba(0,179,126,0.18),transparent_52%),radial-gradient(circle_at_70%_20%,rgba(96,165,250,0.15),transparent_38%),#09131c] shadow-[0_32px_80px_rgba(0,0,0,0.5)]">
            <div class="iphone-scene" data-iphone-scene data-model-src="/assets/models/iphone.gltf" style="position:absolute;inset:0;min-height:100%;">
              <canvas aria-hidden="true"></canvas>
            </div>
          </div>
          <div class="relative aspect-[16/9] overflow-hidden rounded-3xl border border-zinc-800/60 bg-[#0b0b0e]">
            <img src="/case-study-1.svg" alt="Nova Flow desktop dashboard preview" class="h-full w-full object-cover" loading="lazy" />
          </div>
        </figure>
      </article>

      <article class="rounded-2xl bg-[#141417] border border-zinc-800/60 p-5 sm:p-8 transition-all duration-300 hover:border-zinc-700/80">
        <p class="text-xs font-mono uppercase tracking-widest text-accent">Launch Page</p>
        <h3 class="mt-3 sm:mt-4 text-xl sm:text-2xl font-semibold tracking-tight text-white">Productized software offer.</h3>
        <p class="mt-4 sm:mt-6 text-sm sm:text-base text-zinc-400">We crafted a focused campaign page that clearly explains the product, frames the value proposition, and drives visitors toward one primary action.</p>
        <div class="mt-4 sm:mt-6 flex flex-wrap gap-2">
          <span class="rounded-full border border-zinc-700/60 bg-zinc-800/20 px-3 py-1 text-xs text-zinc-400">UI Design</span>
          <span class="rounded-full border border-zinc-700/60 bg-zinc-800/20 px-3 py-1 text-xs text-zinc-400">Conversion</span>
          <span class="rounded-full border border-zinc-700/60 bg-zinc-800/20 px-3 py-1 text-xs text-zinc-400">Copy</span>
        </div>
        <figure class="mt-6 sm:mt-8 overflow-hidden rounded-3xl border border-zinc-800/60 bg-[#0b0b0e]">
          <img src="/case-study-3.svg" alt="Visual outline of a premium productized service offering" class="aspect-[4/3] w-full object-cover" loading="lazy" />
        </figure>
      </article>

      <article class="md:col-span-3 rounded-2xl bg-gradient-to-br from-[#141417] to-[#111115] border border-zinc-800/60 p-5 sm:p-8 transition-all duration-300 hover:border-zinc-700/80">
        <div class="grid gap-6 lg:grid-cols-[0.78fr_1.22fr] lg:items-center">
          <div>
            <p class="text-xs font-mono uppercase tracking-widest text-accent">Premium Commerce</p>
            <h3 class="mt-3 sm:mt-4 text-xl sm:text-2xl font-semibold tracking-tight text-white">AETHER — luxury audio experience.</h3>
            <div class="mt-4 sm:mt-6 space-y-4 text-zinc-400">
              <div>
                <p class="font-semibold text-white">Our vision</p>
                <p class="mt-2 text-sm sm:text-base">We built a refined interface for high-end audio equipment that communicates craft, restraint, and uncompromising quality through every pixel.</p>
              </div>
              <div>
                <p class="font-semibold text-white">What we delivered</p>
                <p class="mt-2 text-sm sm:text-base">Immersive product presentation with clear visual hierarchy, premium motion design, and an interactive 3D product viewer that lets buyers explore from every angle.</p>
              </div>
            </div>
            <div class="mt-4 flex flex-wrap gap-2">
              <span class="rounded-full border border-zinc-700/60 bg-zinc-800/20 px-3 py-1 text-xs text-zinc-400">3D Integration</span>
              <span class="rounded-full border border-zinc-700/60 bg-zinc-800/20 px-3 py-1 text-xs text-zinc-400">Animation</span>
              <span class="rounded-full border border-zinc-700/60 bg-zinc-800/20 px-3 py-1 text-xs text-zinc-400">Luxury UI</span>
            </div>
          </div>
          <div class="relative h-56 overflow-hidden rounded-3xl border border-zinc-800/60 bg-[#0b0b0e] sm:h-80 md:h-96">
            <div class="laptop-scene h-full w-full" data-laptop-scene data-model-src="/assets/models/macbook.glb">
              <canvas aria-hidden="true"></canvas>
            </div>
          </div>
        </div>
      </article>
    </div>
  </section>

  <!-- ==================== SERVICES - 3 TIERS ==================== -->
  <section id="services" class="space-y-10 pb-20">
    <div class="grid gap-6 lg:grid-cols-[0.9fr_1fr] lg:items-end">
      <div class="space-y-4">
        <p class="text-xs font-mono uppercase tracking-widest text-zinc-500">[04 / OUR SERVICES]</p>
        <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">Three tiers of execution — from essential to extraordinary.</h2>
      </div>
      <p class="max-w-3xl text-base leading-8 text-zinc-400">Every engagement includes our full strategic process: discovery, design direction, responsive development, performance engineering, and a clean launch handoff. Choose the tier that matches your ambition.</p>
    </div>

    <div class="grid gap-6 lg:grid-cols-3">
      <!-- TIER 1 -->
      <article class="rounded-2xl bg-[#141417] border border-zinc-800/60 p-8 transition-all duration-300 hover:border-zinc-700/80 group">
        <div class="flex items-center justify-between">
          <p class="text-xs font-mono uppercase tracking-widest text-zinc-500">Tier 1</p>
          <span class="rounded-full bg-zinc-800/40 px-3 py-1 text-[10px] uppercase tracking-widest text-zinc-500">Essential</span>
        </div>
        <h3 class="mt-4 text-2xl font-semibold tracking-tight text-white group-hover:text-accent transition-colors duration-300">High-Performance UI Build</h3>
        <p class="mt-4 text-zinc-400 leading-relaxed">A polished, responsive website with core SEO foundations. Perfect for brands that need a clean, fast, and trustworthy digital presence that converts from day one.</p>
        <ul class="mt-6 space-y-3">
          <li class="flex items-start gap-3 text-sm text-zinc-300">
            <span class="mt-0.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span>
            Responsive, mobile-first UI development
          </li>
          <li class="flex items-start gap-3 text-sm text-zinc-300">
            <span class="mt-0.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span>
            Strategic messaging & content structuring
          </li>
          <li class="flex items-start gap-3 text-sm text-zinc-300">
            <span class="mt-0.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span>
            Core SEO optimization (on-page, meta, schema)
          </li>
          <li class="flex items-start gap-3 text-sm text-zinc-300">
            <span class="mt-0.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span>
            Performance-tuned launch (90+ Lighthouse)
          </li>
        </ul>
        <div class="mt-8 space-y-3">
          <p class="text-3xl font-semibold text-white">$4,500</p>
          <p class="text-sm text-zinc-500">Best for validating a new brand, campaign, or productized offer.</p>
        </div>
        <a href="#contact" class="mt-8 inline-flex w-full items-center justify-center rounded-full border border-zinc-700 bg-[#111113] px-6 py-3 text-sm font-semibold text-zinc-200 transition-all duration-300 ease-out hover:border-zinc-600 hover:text-white">Get Started</a>
      </article>

      <!-- TIER 2 -->
      <article class="rounded-2xl bg-[#141417] border border-accent/40 p-8 shadow-[0_0_60px_rgba(0,179,126,0.08)] transition-all duration-300 hover:border-accent/60 group relative overflow-hidden">
        <div class="absolute top-0 right-0 w-32 h-32 bg-accent/5 rounded-bl-full"></div>
        <div class="flex items-center justify-between">
          <p class="text-xs font-mono uppercase tracking-widest text-accent">Tier 2</p>
          <span class="rounded-full bg-accent/10 px-3 py-1 text-[10px] uppercase tracking-widest text-accent">Most requested</span>
        </div>
        <h3 class="mt-4 text-2xl font-semibold tracking-tight text-white group-hover:text-accent transition-colors duration-300">Advanced UI + Enhanced SEO</h3>
        <p class="mt-4 text-zinc-400 leading-relaxed">Complex UI interactions, enhanced search visibility, and a fast backend. For established brands ready to elevate their digital experience with animations and deeper functionality.</p>
        <ul class="mt-6 space-y-3">
          <li class="flex items-start gap-3 text-sm text-zinc-300">
            <span class="mt-0.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span>
            Everything in Tier 1, plus:
          </li>
          <li class="flex items-start gap-3 text-sm text-zinc-300">
            <span class="mt-0.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span>
            Complex UI interactions & micro-animations
          </li>
          <li class="flex items-start gap-3 text-sm text-zinc-300">
            <span class="mt-0.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span>
            Enhanced SEO strategy (technical SEO, structured data)
          </li>
          <li class="flex items-start gap-3 text-sm text-zinc-300">
            <span class="mt-0.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span>
            Fast backend integration (CMS, API, or static)
          </li>
          <li class="flex items-start gap-3 text-sm text-zinc-300">
            <span class="mt-0.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span>
            Multi-section / multi-page architecture
          </li>
        </ul>
        <div class="mt-8 space-y-3">
          <p class="text-3xl font-semibold text-white">$9,500</p>
          <p class="text-sm text-zinc-500">Best for established brands ready to upgrade their digital presence.</p>
        </div>
        <a href="#contact" class="mt-8 inline-flex w-full items-center justify-center rounded-full bg-accent px-6 py-3 text-sm font-semibold text-black transition-all duration-300 ease-out hover:shadow-[0_0_40px_rgba(0,179,126,0.2)]">Start a Project</a>
      </article>

      <!-- TIER 3 -->
      <article class="rounded-2xl bg-[#141417] border border-zinc-800/60 p-8 transition-all duration-300 hover:border-zinc-700/80 group">
        <div class="flex items-center justify-between">
          <p class="text-xs font-mono uppercase tracking-widest text-zinc-500">Tier 3</p>
          <span class="rounded-full bg-zinc-800/40 px-3 py-1 text-[10px] uppercase tracking-widest text-zinc-500">Premium</span>
        </div>
        <h3 class="mt-4 text-2xl font-semibold tracking-tight text-white group-hover:text-accent transition-colors duration-300">Bespoke + Luxury-Tech Experience</h3>
        <p class="mt-4 text-zinc-400 leading-relaxed">Custom animations, luxury-tech UI design, and robust infrastructure. For visionary brands that demand a groundbreaking digital presence with no compromises.</p>
        <ul class="mt-6 space-y-3">
          <li class="flex items-start gap-3 text-sm text-zinc-300">
            <span class="mt-0.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span>
            Everything in Tier 2, plus:
          </li>
          <li class="flex items-start gap-3 text-sm text-zinc-300">
            <span class="mt-0.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span>
            Bespoke animations & 3D integrations
          </li>
          <li class="flex items-start gap-3 text-sm text-zinc-300">
            <span class="mt-0.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span>
            Luxury-tech UI design system
          </li>
          <li class="flex items-start gap-3 text-sm text-zinc-300">
            <span class="mt-0.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span>
            Robust, scalable infrastructure (CDN, edge, SSR)
          </li>
          <li class="flex items-start gap-3 text-sm text-zinc-300">
            <span class="mt-0.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span>
            Priority support & post-launch optimization
          </li>
        </ul>
        <div class="mt-8 space-y-3">
          <p class="text-3xl font-semibold text-white">$14,500</p>
          <p class="text-sm text-zinc-500">Best for visionary brands that demand an uncompromising digital experience.</p>
        </div>
        <a href="#contact" class="mt-8 inline-flex w-full items-center justify-center rounded-full border border-zinc-700 bg-[#111113] px-6 py-3 text-sm font-semibold text-zinc-200 transition-all duration-300 ease-out hover:border-zinc-600 hover:text-white">Let's Talk</a>
      </article>
    </div>
  </section>

  <!-- ==================== PROCESS ==================== -->
  <section id="process" class="space-y-8 pb-20">
    <div class="space-y-4">
      <p class="text-xs font-mono uppercase tracking-widest text-zinc-500">[05 / OUR PROCESS]</p>
      <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">A straightforward process with no surprises.</h2>
    </div>
    <div class="grid gap-4 sm:gap-6 md:grid-cols-4">
      <article class="rounded-2xl bg-[#141417] border border-zinc-800/60 p-5 sm:p-6 transition-all duration-300 hover:border-zinc-700/80">
        <p class="text-xs font-mono uppercase tracking-widest text-accent">01</p>
        <h3 class="mt-4 text-lg font-semibold text-white">Discover</h3>
        <p class="mt-3 text-sm text-zinc-400">We learn about your brand, audience, goals, and competitive landscape to define the strategic direction.</p>
      </article>
      <article class="rounded-2xl bg-[#141417] border border-zinc-800/60 p-5 sm:p-6 transition-all duration-300 hover:border-zinc-700/80">
        <p class="text-xs font-mono uppercase tracking-widest text-accent">02</p>
        <h3 class="mt-4 text-lg font-semibold text-white">Define</h3>
        <p class="mt-3 text-sm text-zinc-400">We architect the page structure, user flows, messaging hierarchy, and conversion strategy.</p>
      </article>
      <article class="rounded-2xl bg-[#141417] border border-zinc-800/60 p-5 sm:p-6 transition-all duration-300 hover:border-zinc-700/80">
        <p class="text-xs font-mono uppercase tracking-widest text-accent">03</p>
        <h3 class="mt-4 text-lg font-semibold text-white">Create</h3>
        <p class="mt-3 text-sm text-zinc-400">We design and develop the full experience — from UI concepts to responsive, performance-optimized code.</p>
      </article>
      <article class="rounded-2xl bg-[#141417] border border-zinc-800/60 p-5 sm:p-6 transition-all duration-300 hover:border-zinc-700/80">
        <p class="text-xs font-mono uppercase tracking-widest text-accent">04</p>
        <h3 class="mt-4 text-lg font-semibold text-white">Launch</h3>
        <p class="mt-3 text-sm text-zinc-400">We deploy, monitor, and hand over a polished product with everything your team needs to maintain and grow.</p>
      </article>
    </div>
  </section>

  <!-- ==================== CONTACT ==================== -->
  <section id="contact" class="pb-20">
    <div class="grid gap-6 lg:grid-cols-[0.95fr_1.05fr] lg:items-start">
      <div class="space-y-4">
        <p class="text-xs font-mono uppercase tracking-widest text-zinc-500">[06 / START A PROJECT]</p>
        <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">Ready to build something extraordinary together?</h2>
        <p class="max-w-3xl text-base leading-8 text-zinc-400">Tell us about your project, your goals, and your timeline. We will respond within 48 hours with a custom proposal and next steps.</p>
        <div class="mt-6 space-y-4 rounded-2xl border border-zinc-800/60 bg-[#141417] p-6">
          <div class="flex items-center gap-4">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-accent/10">
              <span class="text-accent text-lg">✉</span>
            </div>
            <div>
              <p class="text-sm font-semibold text-white">Email us</p>
              <p class="text-sm text-zinc-400">hello@novastudio.com</p>
            </div>
          </div>
          <div class="flex items-center gap-4">
            <div class="flex h-10 w-10 items-center justify-center rounded-full bg-accent/10">
              <span class="text-accent text-lg">⚡</span>
            </div>
            <div>
              <p class="text-sm font-semibold text-white">Typical response time</p>
              <p class="text-sm text-zinc-400">Within 48 hours</p>
            </div>
          </div>
        </div>
      </div>

      <div class="rounded-[2rem] border border-zinc-800/60 bg-[#141417] p-8 shadow-soft">
        <form class="grid gap-6">
          <label class="block text-sm font-semibold tracking-tight text-zinc-100">
            Name
            <input type="text" name="name" required class="mt-3 w-full rounded-3xl border border-zinc-800/60 bg-[#0d0d11] px-5 py-4 text-sm text-zinc-100 outline-none transition-all duration-300 focus:border-accent/70 focus:ring-2 focus:ring-accent/10" />
          </label>
          <label class="block text-sm font-semibold tracking-tight text-zinc-100">
            Business email
            <input type="email" name="email" required class="mt-3 w-full rounded-3xl border border-zinc-800/60 bg-[#0d0d11] px-5 py-4 text-sm text-zinc-100 outline-none transition-all duration-300 focus:border-accent/70 focus:ring-2 focus:ring-accent/10" />
          </label>
          <label class="block text-sm font-semibold tracking-tight text-zinc-100">
            Company or project name
            <input type="text" name="project" required class="mt-3 w-full rounded-3xl border border-zinc-800/60 bg-[#0d0d11] px-5 py-4 text-sm text-zinc-100 outline-none transition-all duration-300 focus:border-accent/70 focus:ring-2 focus:ring-accent/10" />
          </label>
          <label class="block text-sm font-semibold tracking-tight text-zinc-100">
            Tell us about your project
            <textarea name="brief" rows="5" required placeholder="What are you looking to build? What are your goals and timeline?" class="mt-3 w-full rounded-3xl border border-zinc-800/60 bg-[#0d0d11] px-5 py-4 text-sm text-zinc-100 outline-none transition-all duration-300 focus:border-accent/70 focus:ring-2 focus:ring-accent/10"></textarea>
          </label>
          <button type="submit" class="inline-flex w-full items-center justify-center rounded-full bg-accent px-6 py-4 text-base font-semibold text-black transition-all duration-300 ease-out hover:shadow-[0_0_40px_rgba(0,179,126,0.2)]">Send Project Brief</button>
        </form>
      </div>
    </div>
  </section>
</Layout>

<script>
  import * as THREE from 'three';
  import { RoomEnvironment } from 'three/examples/jsm/environments/RoomEnvironment.js';
  import { GLTFLoader } from 'three/examples/jsm/loaders/GLTFLoader.js';

  const sceneRoots = document.querySelectorAll<HTMLElement>('[data-iphone-scene]');

  sceneRoots.forEach((root) => {
    const canvas = root.querySelector('canvas');
    const modelSrc = root.dataset.modelSrc;

    if (!canvas || !modelSrc) {
      return;
    }

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(34, 1, 0.1, 100);
    const renderer = new THREE.WebGLRenderer({
      canvas,
      alpha: true,
      antialias: true,
      powerPreference: 'high-performance'
    });

    renderer.outputColorSpace = THREE.SRGBColorSpace;
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.08;
    renderer.shadowMap.enabled = true;
    renderer.shadowMap.type = THREE.PCFSoftShadowMap;
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2.5));

    const makeScreenTexture = (source: HTMLImageElement) => {
      const safeTop = Math.round(source.height * 0.04);
      const screenScale = 1.08;
      const canvasTexture = document.createElement('canvas');
      canvasTexture.width = source.width;
      canvasTexture.height = source.height;

      const context = canvasTexture.getContext('2d');

      if (context) {
        const scaledWidth = source.width * screenScale;
        const scaledHeight = source.height * screenScale;
        const offsetX = (source.width - scaledWidth) / 2;

        context.fillStyle = '#031719';
        context.fillRect(0, 0, canvasTexture.width, canvasTexture.height);
        context.drawImage(source, offsetX, safeTop, scaledWidth, scaledHeight);
      }

      const texture = new THREE.CanvasTexture(canvasTexture);
      texture.colorSpace = THREE.SRGBColorSpace;
      texture.flipY = false;
      texture.minFilter = THREE.LinearFilter;
      texture.magFilter = THREE.LinearFilter;
      texture.generateMipmaps = false;
      texture.wrapS = THREE.RepeatWrapping;
      texture.center.set(0.5, 0.5);
      texture.rotation = Math.PI;
      texture.repeat.x = -1;
      texture.anisotropy = renderer.capabilities.getMaxAnisotropy();

      return texture;
    };

    const screenImage = new Image();
    screenImage.src = '/assets/pictures/novaflow-screen.png';
    const screenVideo = document.createElement('video');
    screenVideo.src = '/assets/videos/novaflow-scroll.webm';
    screenVideo.muted = true;
    screenVideo.loop = true;
    screenVideo.playsInline = true;
    screenVideo.preload = 'auto';
    const screenMaterial = new THREE.MeshBasicMaterial({
      color: 0xffffff,
      side: THREE.DoubleSide,
      toneMapped: false
    });
    const bodyMaterial = new THREE.MeshStandardMaterial({
      color: 0x191d20,
      metalness: 0.92,
      roughness: 0.24,
      envMapIntensity: 0.9
    });
    const backMaterial = new THREE.MeshStandardMaterial({
      color: 0x101316,
      metalness: 0.72,
      roughness: 0.34,
      envMapIntensity: 0.72
    });
    const blackGlassMaterial = new THREE.MeshBasicMaterial({
      color: 0x020305,
      side: THREE.DoubleSide,
      toneMapped: false
    });

    let videoTexture: THREE.VideoTexture | null = null;

    screenImage.addEventListener('load', () => {
      if (videoTexture) {
        return;
      }

      const fallbackTexture = makeScreenTexture(screenImage);
      screenMaterial.map?.dispose();
      screenMaterial.map = fallbackTexture;
      screenMaterial.needsUpdate = true;
    });

    const applyVideoTexture = () => {
      videoTexture = new THREE.VideoTexture(screenVideo);
      videoTexture.colorSpace = THREE.SRGBColorSpace;
      videoTexture.flipY = false;
      videoTexture.minFilter = THREE.LinearFilter;
      videoTexture.magFilter = THREE.LinearFilter;
      videoTexture.generateMipmaps = false;
      videoTexture.wrapS = THREE.RepeatWrapping;
      videoTexture.center.set(0.5, 0.5);
      videoTexture.rotation = Math.PI;
      videoTexture.repeat.x = -1;
      videoTexture.anisotropy = renderer.capabilities.getMaxAnisotropy();

      screenMaterial.map?.dispose();
      screenMaterial.map = videoTexture;
      screenMaterial.needsUpdate = true;
    };

    const keyLight = new THREE.DirectionalLight(0xffffff, 4.4);
    keyLight.position.set(4.5, 5.5, 6);
    keyLight.castShadow = true;
    keyLight.shadow.mapSize.set(1024, 1024);
    keyLight.shadow.camera.near = 0.5;
    keyLight.shadow.camera.far = 18;
    keyLight.shadow.camera.left = -5;
    keyLight.shadow.camera.right = 5;
    keyLight.shadow.camera.top = 5;
    keyLight.shadow.camera.bottom = -5;
    scene.add(keyLight);
    scene.add(new THREE.HemisphereLight(0xb9fff1, 0x05070d, 1.35));

    const fillLight = new THREE.PointLight(0x00b37e, 10, 12);
    fillLight.position.set(-3.2, 1.2, 3.4);
    scene.add(fillLight);

    const rimLight = new THREE.PointLight(0x9af7ff, 32, 9);
    rimLight.position.set(-3.8, 2.7, -2.5);
    scene.add(rimLight);

    const edgeLight = new THREE.DirectionalLight(0xdff7ff, 1.45);
    edgeLight.position.set(-2, 3, 3.5);
    scene.add(edgeLight);

    const shadowPlane = new THREE.Mesh(
      new THREE.CircleGeometry(2.25, 48),
      new THREE.ShadowMaterial({ color: 0x000000, opacity: 0.24 })
    );
    shadowPlane.position.set(0, -1.68, -0.55);
    shadowPlane.scale.set(1.25, 0.22, 1);
    shadowPlane.receiveShadow = true;
    scene.add(shadowPlane);

    const phoneGroup = new THREE.Group();
    phoneGroup.rotation.set(-0.08, -0.35, 0.03);
    scene.add(phoneGroup);

    const loader = new GLTFLoader();
    let model: THREE.Object3D | null = null;
    let animationFrame = 0;
    let pointerX = 0;
    let pointerY = 0;
    let isAnimating = false;
    let isSceneVisible = true;
    let isPageVisible = !document.hidden;

    const shouldAnimate = () => isSceneVisible && isPageVisible;

    const syncVideoPlayback = () => {
      if (!videoTexture) {
        return;
      }

      if (shouldAnimate()) {
        void screenVideo.play().catch(() => undefined);
      } else {
        screenVideo.pause();
      }
    };

    const stopFrame = () => {
      if (!isAnimating) {
        return;
      }

      window.cancelAnimationFrame(animationFrame);
      isAnimating = false;
    };

    const resize = () => {
      const { width, height } = root.getBoundingClientRect();
      renderer.setSize(width, height, false);
      camera.aspect = width / Math.max(height, 1);
      camera.position.set(0, 0.05, width < 560 ? 7 : 6.25);
      camera.updateProjectionMatrix();
    };

    const frame = () => {
      if (!shouldAnimate()) {
        isAnimating = false;
        return;
      }

      animationFrame = window.requestAnimationFrame(frame);
      const time = performance.now() * 0.001;

      phoneGroup.rotation.y += ((-0.35 + pointerX * 0.22) - phoneGroup.rotation.y) * 0.05;
      phoneGroup.rotation.x += ((-0.08 + pointerY * 0.12) - phoneGroup.rotation.x) * 0.05;
      phoneGroup.position.y = 0.28 + Math.sin(time * 1.35) * 0.06;

      renderer.render(scene, camera);
    };

    const startFrame = () => {
      if (isAnimating || !shouldAnimate()) {
        return;
      }

      isAnimating = true;
      animationFrame = window.requestAnimationFrame(frame);
    };

    screenVideo.addEventListener('loadeddata', () => {
      applyVideoTexture();
      syncVideoPlayback();
    }, { once: true });

    screenVideo.load();

    root.addEventListener('pointermove', (event) => {
      const rect = root.getBoundingClientRect();
      pointerX = ((event.clientX - rect.left) / rect.width - 0.5) * 2;
      pointerY = -(((event.clientY - rect.top) / rect.height - 0.5) * 2);
    });

    root.addEventListener('pointerleave', () => {
      pointerX = 0;
      pointerY = 0;
    });

    loader.load(
      modelSrc,
      (gltf) => {
        model = gltf.scene;

        model.traverse((object) => {
          if (object.name.toLowerCase() === 'floor') {
            object.visible = false;
          }

          const meshCandidate = object as THREE.Object3D & { isMesh?: boolean; material?: THREE.Material | THREE.Material[] };
          const meshName = object.name.toLowerCase();
          const parentName = object.parent?.name.toLowerCase() ?? '';
          const normalizedName = meshName.replace(/[\s-]+/g, '_');
          const normalizedParentName = parentName.replace(/[\s-]+/g, '_');

          if (meshCandidate.isMesh && meshName === 'screen') {
            meshCandidate.castShadow = false;
            meshCandidate.receiveShadow = false;
            meshCandidate.material = screenMaterial;
            return;
          }

          if (
            meshCandidate.isMesh &&
            (
              normalizedName === 'screen_border' ||
              normalizedParentName.includes('dynamic_island') ||
              normalizedParentName.includes('camera') ||
              normalizedParentName.includes('cam') ||
              normalizedName.includes('cam')
            )
          ) {
            meshCandidate.castShadow = true;
            meshCandidate.receiveShadow = true;
            meshCandidate.material = blackGlassMaterial;
            return;
          }

          if (meshCandidate.isMesh && normalizedName === 'back_side') {
            meshCandidate.castShadow = true;
            meshCandidate.receiveShadow = true;
            meshCandidate.material = backMaterial;
            return;
          }

          if (meshCandidate.isMesh) {
            meshCandidate.castShadow = true;
            meshCandidate.receiveShadow = true;
            meshCandidate.material = bodyMaterial;
          }
        });

        const box = new THREE.Box3();
        model.traverse((object) => {
          const meshCandidate = object as THREE.Object3D & { isMesh?: boolean };

          if (meshCandidate.isMesh && object.visible) {
            box.expandByObject(object);
          }
        });

        if (box.isEmpty()) {
          box.setFromObject(model);
        }

        const size = box.getSize(new THREE.Vector3());
        const center = box.getCenter(new THREE.Vector3());
        const maxAxis = Math.max(size.x, size.y, size.z);
        const scale = 3.05 / Math.max(maxAxis, 1);

        model.scale.setScalar(scale);
        model.position.set(-center.x * scale, -center.y * scale, -center.z * scale);
        phoneGroup.add(model);
        root.classList.add('is-loaded');
      },
      undefined,
      () => {
        root.classList.add('has-failed');
      }
    );

    resize();
    startFrame();

    const observer = new ResizeObserver(resize);
    observer.observe(root);

    const visibilityObserver = new IntersectionObserver(([entry]) => {
      isSceneVisible = entry.isIntersecting;

      if (shouldAnimate()) {
        startFrame();
      } else {
        stopFrame();
      }

      syncVideoPlayback();
    }, { threshold: 0.05 });
    visibilityObserver.observe(root);

    const handleVisibilityChange = () => {
      isPageVisible = !document.hidden;

      if (shouldAnimate()) {
        startFrame();
      } else {
        stopFrame();
      }

      syncVideoPlayback();
    };
    document.addEventListener('visibilitychange', handleVisibilityChange);

    document.addEventListener('astro:before-swap', () => {
      stopFrame();
      observer.disconnect();
      visibilityObserver.disconnect();
      document.removeEventListener('visibilitychange', handleVisibilityChange);
      screenVideo.pause();
      screenMaterial.map?.dispose();
      videoTexture?.dispose();
      renderer.dispose();
    }, { once: true });
  });

  // Laptop scene for AETHER case study (separate from phone scene)
  const laptopScenes = document.querySelectorAll<HTMLElement>('[data-laptop-scene]');
  laptopScenes.forEach((root) => {
    const canvas = root.querySelector('canvas');
    const modelSrc = root.dataset.modelSrc;
    if (!canvas || !modelSrc) return;

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(34, 1, 0.1, 100);
    const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true, powerPreference: 'high-performance' });
    renderer.outputColorSpace = THREE.SRGBColorSpace;
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.12;
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.shadowMap.enabled = true;
    renderer.shadowMap.type = THREE.PCFSoftShadowMap;

    const pmremGenerator = new THREE.PMREMGenerator(renderer);
    const environmentMap = pmremGenerator.fromScene(new RoomEnvironment(), 0.04).texture;
    scene.environment = environmentMap;
    pmremGenerator.dispose();
    scene.add(new THREE.HemisphereLight(0xffffff, 0x404040, 1.2));
    const keyLight = new THREE.DirectionalLight(0xfff2dd, 1.8);
    keyLight.position.set(2, 3, 2);
    keyLight.castShadow = true;
    scene.add(keyLight);
    const laptopGroup = new THREE.Group();
    scene.add(laptopGroup);

    // SHARED screen material — all textured meshes get this same instance
    const screenMaterial = new THREE.MeshBasicMaterial({ color: 0xffffff, side: THREE.DoubleSide, toneMapped: false });

    let animationFrame = 0;
    let isAnimating = false;
    let isSceneVisible = true;
    let isPageVisible = !document.hidden;
    let videoTexture: THREE.VideoTexture | null = null;
    let videoElement: HTMLVideoElement | null = null;
    let pointerX = 0;
    let pointerY = 0;
    const shouldAnimate = () => isSceneVisible && isPageVisible;

    const resize = () => {
      const { width, height } = root.getBoundingClientRect();
      renderer.setSize(width, height, false);
      camera.aspect = width / Math.max(height, 1);
      camera.position.set(-0.8, 0.6, 2.8);
      camera.lookAt(0, 0.2, 0);
      camera.updateProjectionMatrix();
    };

    const frame = () => {
      if (!shouldAnimate()) { isAnimating = false; return; }
      animationFrame = window.requestAnimationFrame(frame);
      const time = performance.now() * 0.001;
      laptopGroup.rotation.y += (pointerX * 0.02 + Math.sin(time * 0.32) * 0.006 - laptopGroup.rotation.y) * 0.04;
      laptopGroup.rotation.x += (pointerY * 0.015 + Math.sin(time * 0.28) * 0.004 - laptopGroup.rotation.x) * 0.04;
      laptopGroup.position.y = Math.sin(time * 0.28) * 0.004;
      if (videoTexture) videoTexture.needsUpdate = true;
      renderer.render(scene, camera);
    };

    const startFrame = () => { if (isAnimating || !shouldAnimate()) return; isAnimating = true; animationFrame = window.requestAnimationFrame(frame); };
    const stopFrame = () => { if (!isAnimating) return; window.cancelAnimationFrame(animationFrame); isAnimating = false; };

    const loadModel = () => {
      const loader = new GLTFLoader();
      loader.load(modelSrc, (gltf) => {
        const model = gltf.scene;
        model.updateMatrixWorld(true);

        // Create video element
        videoElement = document.createElement('video');
        videoElement.src = '/assets/videos/laptop-screen.mp4#t=8';
        videoElement.muted = true;
        videoElement.loop = true;
        videoElement.playsInline = true;
        videoElement.preload = 'auto';
        videoElement.style.display = 'none';
        videoElement.setAttribute('playsinline', '');
        document.body.appendChild(videoElement);

        // Find screen mesh (Object_123) per DEVICE_SCREEN_TEXTURE_README.md spec
        model.traverse((object) => {
          const mesh = object as THREE.Object3D & { isMesh?: boolean; material?: THREE.Material | THREE.Material[] };
          if (!mesh.isMesh) return;
          const name = object.name.toLowerCase().replace(/[\s-]+/g, '_');
          const match = name.match(/object_(\d+)/);
          if (match) {
            const num = parseInt(match[1], 10);
            if (num === 123) {
              // Screen mesh — assign shared screen material
              mesh.material = screenMaterial;
              mesh.castShadow = false;
              mesh.receiveShadow = false;
            }
          }
        });

        // Size and position model
        const box = new THREE.Box3();
        model.traverse((object) => {
          const mesh = object as THREE.Object3D & { isMesh?: boolean };
          if (mesh.isMesh && object.visible) box.expandByObject(object);
        });
        const size = box.getSize(new THREE.Vector3());
        const center = box.getCenter(new THREE.Vector3());
        const maxAxis = Math.max(size.x, size.y, size.z);
        const modelScale = 3.35 / Math.max(maxAxis, 1);
        model.scale.setScalar(modelScale);
        model.position.set(-center.x * modelScale, -center.y * modelScale, -center.z * modelScale);
        laptopGroup.add(model);
        laptopGroup.rotation.set(-0.15, -0.4, 0);

        // When video loads, set it as the map on the shared screenMaterial
        videoElement.addEventListener('loadeddata', () => {
          videoTexture = new THREE.VideoTexture(videoElement!);
          videoTexture.colorSpace = THREE.SRGBColorSpace;
          videoTexture.flipY = false;
          videoTexture.minFilter = THREE.LinearFilter;
          videoTexture.magFilter = THREE.LinearFilter;
          videoTexture.generateMipmaps = false;
          videoTexture.wrapT = THREE.RepeatWrapping;
          videoTexture.repeat.y = -1;
          videoTexture.offset.y = 1;
          videoTexture.rotation = 0;

          // Since all textured meshes SHARE screenMaterial, one update affects all
          screenMaterial.map?.dispose();
          screenMaterial.map = videoTexture;
          screenMaterial.needsUpdate = true;

          if (shouldAnimate()) void videoElement!.play().catch(() => undefined);
        }, { once: true });

        videoElement.load();
        root.classList.add('is-loaded');
        resize();
        startFrame();
      }, undefined, () => { root.classList.add('has-failed'); });
    };

    const loadObserver = new IntersectionObserver(([entry]) => {
      if (entry.isIntersecting) { loadModel(); loadObserver.disconnect(); }
    }, { rootMargin: '50px' });
    loadObserver.observe(root);

    const resizeObserver = new ResizeObserver(resize);
    resizeObserver.observe(root);

    root.addEventListener('pointermove', (event) => {
      const rect = root.getBoundingClientRect();
      pointerX = ((event.clientX - rect.left) / rect.width - 0.5) * 2;
      pointerY = -(((event.clientY - rect.top) / rect.height - 0.5) * 2);
    });
    root.addEventListener('pointerleave', () => { pointerX = 0; pointerY = 0; });

    const visibilityObserver = new IntersectionObserver(([entry]) => {
      isSceneVisible = entry.isIntersecting;
      if (shouldAnimate()) { startFrame(); if (videoTexture && videoElement) void videoElement.play().catch(() => undefined); }
      else { stopFrame(); videoElement?.pause(); }
    }, { threshold: 0.05 });
    visibilityObserver.observe(root);

    document.addEventListener('visibilitychange', () => {
      isPageVisible = !document.hidden;
      if (shouldAnimate()) { startFrame(); if (videoTexture && videoElement) void videoElement.play().catch(() => undefined); }
      else { stopFrame(); videoElement?.pause(); }
    });

    document.addEventListener('astro:before-swap', () => {
      stopFrame();
      resizeObserver.disconnect();
      visibilityObserver.disconnect();
      videoElement?.pause();
      videoTexture?.dispose();
      environmentMap.dispose();
      renderer.dispose();
    }, { once: true });
  });
</script>