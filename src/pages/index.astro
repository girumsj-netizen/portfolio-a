        }
        html.light .font-mono.text-zinc-500 { color: #059669 !important; }
        html.light .rounded-full.border.border-zinc-700\\/60.bg-zinc-800\\/20 {
          background-color: #f1f5f9 !important;
          border-color: #e2e8f0 !important;
        }
        html.light a.rounded-full.border.border-zinc-700.bg-\\[\\#111113\\],
        html.light button.rounded-full.border.border-zinc-700.bg-\\[\\#111113\\] {
          background-color: rgba(5, 150, 105, 0.10) !important;
          border-color: rgba(5, 150, 105, 0.20) !important;
          color: #059669 !important;
        }
        html.light .max-w-4xl.rounded-2xl.border.border-zinc-800\\/60 {
          background: linear-gradient(145deg, rgba(209, 250, 229, 0.90), rgba(240, 253, 244, 0.82)) !important;
          backdrop-filter: blur(8px) !important;
          -webkit-backdrop-filter: blur(8px) !important;
          border-color: #DCFCE7 !important;
        }
      `;
      document.head.appendChild(style);
    })();

    // Tab switching system
    (function() {
      const tabs = document.querySelectorAll('.tab-btn');
      const panels = {
        studio: document.getElementById('panel-studio'),
        work: document.getElementById('panel-work'),
        services: document.getElementById('panel-services'),
        contact: document.getElementById('panel-contact')
      };

      const switchTab = (tabId) => {
        // Update button states
        tabs.forEach(btn => {
          const isActive = btn.dataset.tab === tabId;
          btn.classList.toggle('active', isActive);
          btn.setAttribute('data-active', isActive ? 'true' : 'false');
        });

        // Show/hide panels and trigger animations
        Object.entries(panels).forEach(([id, panel]) => {
          if (id === tabId) {
            panel.classList.remove('hidden');
            panel.classList.add('active');
            panel.classList.remove('is-active');
            // Trigger reflow to restart animation
            void panel.offsetHeight;
            panel.classList.add('is-active');
            // Scroll panel into view smoothly
            window.scrollTo({ top: 0, behavior: 'smooth' });
            // Trigger scroll-based reveals for this panel
            const reveals = panel.querySelectorAll('.reveal, .reveal-fade, .reveal-stagger');
            reveals.forEach(el => { el.classList.remove('is-visible'); });
            requestAnimationFrame(() => {
              requestAnimationFrame(() => {
                reveals.forEach(el => el.classList.add('is-visible'));
              });
            });
          } else {
            panel.classList.add('hidden');
            panel.classList.remove('active');
            panel.classList.remove('is-active');
          }
        });
      };

      tabs.forEach(btn => {
        btn.addEventListener('click', () => switchTab(btn.dataset.tab));
      });

      // Cross-tab navigation buttons (data-tab-target)
      document.querySelectorAll('[data-tab-target]').forEach(btn => {
        btn.addEventListener('click', () => switchTab(btn.dataset.tabTarget));
      });

      // Work sub-tab switching
      const subTabs = document.querySelectorAll('.work-subtab-btn');
      const workSubs = {
        websites: document.getElementById('work-websites'),
        branding: document.getElementById('work-branding'),
        apps: document.getElementById('work-apps')
      };

      subTabs.forEach(btn => {
        btn.addEventListener('click', () => {
          const sub = btn.dataset.subtab;
          subTabs.forEach(b => {
            const isActive = b.dataset.subtab === sub;
            b.classList.toggle('active', isActive);
            b.setAttribute('data-active', isActive ? 'true' : 'false');
          });
          Object.entries(workSubs).forEach(([id, panel]) => {
            panel.classList.toggle('hidden', id !== sub);
            panel.classList.toggle('active', id === sub);
          });
        });
      });

      // Hero device toggle (phone / laptop)
      const heroToggle = document.getElementById('hero-device-toggle');
      if (heroToggle) {
        const heroScenes = heroToggle.parentElement?.querySelectorAll('.hero-device-scene');
        heroToggle.querySelectorAll('button').forEach(btn => {
          btn.addEventListener('click', () => {
            const device = btn.dataset.device;
            heroToggle.querySelectorAll('button').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            heroScenes?.forEach(scene => {
              const isTarget = scene.dataset.deviceScene === device;
              scene.style.display = isTarget ? '' : 'none';
              if (isTarget) {
                // Trigger resize for the newly visible scene
                const canvas = scene.querySelector('canvas');
                if (canvas) {
                  canvas.style.opacity = '1';
                  scene.dispatchEvent(new Event('resize'));
                }
              }
            });
          });
        });
      }
    })();

    import * as THREE from 'three';
    import { RoomEnvironment } from 'three/examples/jsm/environments/RoomEnvironment.js';
    import { GLTFLoader } from 'three/examples/jsm/loaders/GLTFLoader.js';

  const sceneRoots = document.querySelectorAll<HTMLElement>('[data-iphone-scene]');

  sceneRoots.forEach((root) => {
    const canvas = root.querySelector('canvas');
    const modelSrc = root.dataset.modelSrc;

    if (!canvas || !modelSrc) {
      return;
    }

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(34, 1, 0.1, 100);
    const renderer = new THREE.WebGLRenderer({
      canvas,
      alpha: true,
      antialias: true,
      powerPreference: 'high-performance'
    });

    renderer.outputColorSpace = THREE.SRGBColorSpace;
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.08;
    renderer.shadowMap.enabled = true;
    renderer.shadowMap.type = THREE.PCFSoftShadowMap;
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2.5));

    const makeScreenTexture = (source: HTMLImageElement) => {
      const safeTop = Math.round(source.height * 0.04);
      const screenScale = 1.08;
      const canvasTexture = document.createElement('canvas');
      canvasTexture.width = source.width;
      canvasTexture.height = source.height;
      const context = canvasTexture.getContext('2d');
      if (context) {
        const scaledWidth = source.width * screenScale;
        const scaledHeight = source.height * screenScale;
        const offsetX = (source.width - scaledWidth) / 2;
        context.fillStyle = '#031719';
        context.fillRect(0, 0, canvasTexture.width, canvasTexture.height);
        context.drawImage(source, offsetX, safeTop, scaledWidth, scaledHeight);
      }
      const texture = new THREE.CanvasTexture(canvasTexture);
      texture.colorSpace = THREE.SRGBColorSpace;
      texture.flipY = false;
      texture.minFilter = THREE.LinearFilter;
      texture.magFilter = THREE.LinearFilter;
      texture.generateMipmaps = false;
      texture.wrapS = THREE.RepeatWrapping;
      texture.center.set(0.5, 0.5);
      texture.rotation = Math.PI;
      texture.repeat.x = -1;
      texture.anisotropy = renderer.capabilities.getMaxAnisotropy();
      return texture;
    };

    const screenImage = new Image();
    screenImage.src = '/assets/pictures/novaflow-screen.png';
    const screenVideo = document.createElement('video');
    screenVideo.src = '/assets/videos/novaflow-scroll.webm';
    screenVideo.muted = true;
    screenVideo.loop = true;
    screenVideo.playsInline = true;
    screenVideo.preload = 'auto';
    const screenMaterial = new THREE.MeshBasicMaterial({
      color: 0xffffff,
      side: THREE.DoubleSide,
      toneMapped: false
    });
    const bodyMaterial = new THREE.MeshStandardMaterial({
      color: 0x191d20,
      metalness: 0.92,
      roughness: 0.24,
      envMapIntensity: 0.9
    });
    const backMaterial = new THREE.MeshStandardMaterial({
      color: 0x101316,
      metalness: 0.72,
      roughness: 0.34,
      envMapIntensity: 0.72
    });
    const blackGlassMaterial = new THREE.MeshBasicMaterial({
      color: 0x020305,
      side: THREE.DoubleSide,
      toneMapped: false
    });

    let videoTexture: THREE.VideoTexture | null = null;

    screenImage.addEventListener('load', () => {
      if (videoTexture) { return; }
      const fallbackTexture = makeScreenTexture(screenImage);
      screenMaterial.map?.dispose();
      screenMaterial.map = fallbackTexture;
      screenMaterial.needsUpdate = true;
    });

    const applyVideoTexture = () => {
      videoTexture = new THREE.VideoTexture(screenVideo);
      videoTexture.colorSpace = THREE.SRGBColorSpace;
      videoTexture.flipY = false;
      videoTexture.minFilter = THREE.LinearFilter;
      videoTexture.magFilter = THREE.LinearFilter;
      videoTexture.generateMipmaps = false;
      videoTexture.wrapS = THREE.RepeatWrapping;
      videoTexture.center.set(0.5, 0.5);
      videoTexture.rotation = Math.PI;
      videoTexture.repeat.x = -1;
      videoTexture.anisotropy = renderer.capabilities.getMaxAnisotropy();
      screenMaterial.map?.dispose();
      screenMaterial.map = videoTexture;
      screenMaterial.needsUpdate = true;
    };

    const keyLight = new THREE.DirectionalLight(0xffffff, 4.4);
    keyLight.position.set(4.5, 5.5, 6);
    keyLight.castShadow = true;
    keyLight.shadow.mapSize.set(1024, 1024);
    keyLight.shadow.camera.near = 0.5;
    keyLight.shadow.camera.far = 18;
    keyLight.shadow.camera.left = -5;
    keyLight.shadow.camera.right = 5;
    keyLight.shadow.camera.top = 5;
    keyLight.shadow.camera.bottom = -5;
    scene.add(keyLight);
    scene.add(new THREE.HemisphereLight(0xb9fff1, 0x05070d, 1.35));

    const fillLight = new THREE.PointLight(0x00b37e, 10, 12);
    fillLight.position.set(-3.2, 1.2, 3.4);
    scene.add(fillLight);

    const rimLight = new THREE.PointLight(0x9af7ff, 32, 9);
    rimLight.position.set(-3.8, 2.7, -2.5);
    scene.add(rimLight);

    const edgeLight = new THREE.DirectionalLight(0xdff7ff, 1.45);
    edgeLight.position.set(-2, 3, 3.5);
    scene.add(edgeLight);

    const shadowPlane = new THREE.Mesh(
      new THREE.CircleGeometry(2.25, 48),
      new THREE.ShadowMaterial({ color: 0x000000, opacity: 0.24 })
    );
    shadowPlane.position.set(0, -1.68, -0.55);
    shadowPlane.scale.set(1.25, 0.22, 1);
    shadowPlane.receiveShadow = true;
    scene.add(shadowPlane);

    const phoneGroup = new THREE.Group();
    phoneGroup.rotation.set(-0.08, -0.35, 0.03);
    scene.add(phoneGroup);

    const loader = new GLTFLoader();
    let model: THREE.Object3D | null = null;
    let animationFrame = 0;
    let pointerX = 0;
    let pointerY = 0;
    let isAnimating = false;
    let isSceneVisible = true;
    let isPageVisible = !document.hidden;

    const shouldAnimate = () => isSceneVisible && isPageVisible;

    const syncVideoPlayback = () => {
      if (!videoTexture) { return; }
      if (shouldAnimate()) { void screenVideo.play().catch(() => undefined); }
      else { screenVideo.pause(); }
    };

    const stopFrame = () => {
      if (!isAnimating) { return; }
      window.cancelAnimationFrame(animationFrame);
      isAnimating = false;
    };

    const resize = () => {
      const { width, height } = root.getBoundingClientRect();
      renderer.setSize(width, height, false);
      camera.aspect = width / Math.max(height, 1);
      camera.position.set(0, 0.05, width < 560 ? 7 : 6.25);
      camera.updateProjectionMatrix();
    };

    const frame = () => {
      if (!shouldAnimate()) { isAnimating = false; return; }
      animationFrame = window.requestAnimationFrame(frame);
      const time = performance.now() * 0.001;
      phoneGroup.rotation.y += ((-0.35 + pointerX * 0.22) - phoneGroup.rotation.y) * 0.05;
      phoneGroup.rotation.x += ((-0.08 + pointerY * 0.12) - phoneGroup.rotation.x) * 0.05;
      phoneGroup.position.y = 0.28 + Math.sin(time * 1.35) * 0.06;
      renderer.render(scene, camera);
    };

    const startFrame = () => {
      if (isAnimating || !shouldAnimate()) { return; }
      isAnimating = true;
      animationFrame = window.requestAnimationFrame(frame);
    };

    screenVideo.addEventListener('loadeddata', () => {
      applyVideoTexture();
      syncVideoPlayback();
    }, { once: true });
    screenVideo.load();

    root.addEventListener('pointermove', (event) => {
      const rect = root.getBoundingClientRect();
      pointerX = ((event.clientX - rect.left) / rect.width - 0.5) * 2;
      pointerY = -(((event.clientY - rect.top) / rect.height - 0.5) * 2);
    });
    root.addEventListener('pointerleave', () => { pointerX = 0; pointerY = 0; });

    loader.load(modelSrc, (gltf) => {
      model = gltf.scene;
      model.traverse((object) => {
        if (object.name.toLowerCase() === 'floor') { object.visible = false; }
        const meshCandidate = object as THREE.Object3D & { isMesh?: boolean; material?: THREE.Material | THREE.Material[] };
        const meshName = object.name.toLowerCase();
        const parentName = object.parent?.name.toLowerCase() ?? '';
        const normalizedName = meshName.replace(/[\s-]+/g, '_');
        const normalizedParentName = parentName.replace(/[\s-]+/g, '_');
        if (meshCandidate.isMesh && meshName === 'screen') {
          meshCandidate.castShadow = false; meshCandidate.receiveShadow = false; meshCandidate.material = screenMaterial; return;
        }
        if (meshCandidate.isMesh && (normalizedName === 'screen_border' || normalizedParentName.includes('dynamic_island') || normalizedParentName.includes('camera') || normalizedParentName.includes('cam') || normalizedName.includes('cam'))) {
          meshCandidate.castShadow = true; meshCandidate.receiveShadow = true; meshCandidate.material = blackGlassMaterial; return;
        }
        if (meshCandidate.isMesh && normalizedName === 'back_side') {
          meshCandidate.castShadow = true; meshCandidate.receiveShadow = true; meshCandidate.material = backMaterial; return;
        }
        if (meshCandidate.isMesh) {
          meshCandidate.castShadow = true; meshCandidate.receiveShadow = true; meshCandidate.material = bodyMaterial;
        }
      });
      const box = new THREE.Box3();
      model.traverse((object) => {
        const meshCandidate = object as THREE.Object3D & { isMesh?: boolean };
        if (meshCandidate.isMesh && object.visible) { box.expandByObject(object); }
      });
      if (box.isEmpty()) { box.setFromObject(model); }
      const size = box.getSize(new THREE.Vector3());
      const center = box.getCenter(new THREE.Vector3());
      const maxAxis = Math.max(size.x, size.y, size.z);
      const scale = 3.05 / Math.max(maxAxis, 1);
      model.scale.setScalar(scale);
      model.position.set(-center.x * scale, -center.y * scale, -center.z * scale);
      phoneGroup.add(model);
      root.classList.add('is-loaded');
    }, undefined, () => { root.classList.add('has-failed'); });

    resize();
    startFrame();

    const observer = new ResizeObserver(resize);
    observer.observe(root);

    const visibilityObserver = new IntersectionObserver(([entry]) => {
      isSceneVisible = entry.isIntersecting;
      if (shouldAnimate()) { startFrame(); } else { stopFrame(); }
      syncVideoPlayback();
    }, { threshold: 0.05 });
    visibilityObserver.observe(root);

    const handleVisibilityChange = () => {
      isPageVisible = !document.hidden;
      if (shouldAnimate()) { startFrame(); } else { stopFrame(); }
      syncVideoPlayback();
    };
    document.addEventListener('visibilitychange', handleVisibilityChange);

    document.addEventListener('astro:before-swap', () => {
      stopFrame();
      observer.disconnect();
      visibilityObserver.disconnect();
      document.removeEventListener('visibilitychange', handleVisibilityChange);
      screenVideo.pause();
      screenMaterial.map?.dispose();
      videoTexture?.dispose();
      renderer.dispose();
    }, { once: true });
  });

  // Laptop scene for AETHER case study
  const laptopScenes = document.querySelectorAll<HTMLElement>('[data-laptop-scene]');
  laptopScenes.forEach((root) => {
    const canvas = root.querySelector('canvas');
    const modelSrc = root.dataset.modelSrc;
    if (!canvas || !modelSrc) return;

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(34, 1, 0.1, 100);
    const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: true, powerPreference: 'high-performance' });
    renderer.outputColorSpace = THREE.SRGBColorSpace;
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.12;
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
    renderer.shadowMap.enabled = true;
    renderer.shadowMap.type = THREE.PCFSoftShadowMap;

    const pmremGenerator = new THREE.PMREMGenerator(renderer);
    const environmentMap = pmremGenerator.fromScene(new RoomEnvironment(), 0.04).texture;
    scene.environment = environmentMap;
    pmremGenerator.dispose();
    scene.add(new THREE.HemisphereLight(0xffffff, 0x404040, 1.2));
    const keyLight = new THREE.DirectionalLight(0xfff2dd, 1.8);
    keyLight.position.set(2, 3, 2);
    keyLight.castShadow = true;
    scene.add(keyLight);
    const laptopGroup = new THREE.Group();
    scene.add(laptopGroup);

    const screenMaterial = new THREE.MeshBasicMaterial({ color: 0xffffff, side: THREE.DoubleSide, toneMapped: false });

    let animationFrame = 0;
    let isAnimating = false;
    let isSceneVisible = true;
    let isPageVisible = !document.hidden;
    let videoTexture: THREE.VideoTexture | null = null;
    let videoElement: HTMLVideoElement | null = null;
    let pointerX = 0;
    let pointerY = 0;
    const shouldAnimate = () => isSceneVisible && isPageVisible;

    const resize = () => {
      const { width, height } = root.getBoundingClientRect();
      renderer.setSize(width, height, false);
      camera.aspect = width / Math.max(height, 1);
      camera.position.set(-0.8, 0.6, 2.8);
      camera.lookAt(0, 0.2, 0);
      camera.updateProjectionMatrix();
    };

    const frame = () => {
      if (!shouldAnimate()) { isAnimating = false; return; }
      animationFrame = window.requestAnimationFrame(frame);
      const time = performance.now() * 0.001;
      laptopGroup.rotation.y += (pointerX * 0.02 + Math.sin(time * 0.32) * 0.006 - laptopGroup.rotation.y) * 0.04;
      laptopGroup.rotation.x += (pointerY * 0.015 + Math.sin(time * 0.28) * 0.004 - laptopGroup.rotation.x) * 0.04;
      laptopGroup.position.y = Math.sin(time * 0.28) * 0.004;
      if (videoTexture) videoTexture.needsUpdate = true;
      renderer.render(scene, camera);
    };
    const startFrame = () => { if (isAnimating || !shouldAnimate()) return; isAnimating = true; animationFrame = window.requestAnimationFrame(frame); };
    const stopFrame = () => { if (!isAnimating) return; window.cancelAnimationFrame(animationFrame); isAnimating = false; };

    const loadModel = () => {
      const loader = new GLTFLoader();
      loader.load(modelSrc, (gltf) => {
        const model = gltf.scene;
        model.updateMatrixWorld(true);
        videoElement = document.createElement('video');
        videoElement.src = '/assets/videos/laptop-screen.mp4#t=8';
        videoElement.muted = true;
        videoElement.loop = true;
        videoElement.playsInline = true;
        videoElement.preload = 'auto';
        videoElement.style.display = 'none';
        videoElement.setAttribute('playsinline', '');
        document.body.appendChild(videoElement);

        const screenImageSrc = root.dataset.screenImage;
        model.traverse((object) => {
          const mesh = object as THREE.Object3D & { isMesh?: boolean; material?: THREE.Material | THREE.Material[] };
          if (!mesh.isMesh) return;
          const name = object.name.toLowerCase().replace(/[\s-]+/g, '_');
          const match = name.match(/object_(\d+)/);
          if (match) {
            const num = parseInt(match[1], 10);
            if (num === 123) {
              mesh.material = screenMaterial;
              mesh.castShadow = false;
              mesh.receiveShadow = false;
            }
          }
        });

        const box = new THREE.Box3();
        model.traverse((object) => {
          const mesh = object as THREE.Object3D & { isMesh?: boolean };
          if (mesh.isMesh && object.visible) box.expandByObject(object);
        });
        const size = box.getSize(new THREE.Vector3());
        const center = box.getCenter(new THREE.Vector3());
        const maxAxis = Math.max(size.x, size.y, size.z);
        const modelScale = 3.35 / Math.max(maxAxis, 1);
        model.scale.setScalar(modelScale);
        model.position.set(-center.x * modelScale, -center.y * modelScale, -center.z * modelScale);
        laptopGroup.add(model);
        laptopGroup.rotation.set(-0.15, -0.4, 0);

        if (screenImageSrc) {
          const img = new Image();
          img.crossOrigin = 'anonymous';
          img.src = screenImageSrc;
          img.onload = () => {
            const imageTexture = new THREE.Texture(img);
            imageTexture.colorSpace = THREE.SRGBColorSpace;
            imageTexture.minFilter = THREE.LinearFilter;
            imageTexture.magFilter = THREE.LinearFilter;
            imageTexture.generateMipmaps = false;
            imageTexture.needsUpdate = true;
            screenMaterial.map?.dispose();
            screenMaterial.map = imageTexture;
            screenMaterial.needsUpdate = true;
          };
        } else {
          videoElement = document.createElement('video');
          videoElement.src = '/assets/videos/laptop-screen.mp4#t=8';
          videoElement.muted = true;
          videoElement.loop = true;
          videoElement.playsInline = true;
          videoElement.preload = 'auto';
          videoElement.style.display = 'none';
          videoElement.setAttribute('playsinline', '');
          document.body.appendChild(videoElement);

          videoElement.addEventListener('loadeddata', () => {
            videoTexture = new THREE.VideoTexture(videoElement!);
            videoTexture.colorSpace = THREE.SRGBColorSpace;
            videoTexture.flipY = false;
            videoTexture.minFilter = THREE.LinearFilter;
            videoTexture.magFilter = THREE.LinearFilter;
            videoTexture.generateMipmaps = false;
            videoTexture.wrapT = THREE.RepeatWrapping;
            videoTexture.repeat.y = -1;
            videoTexture.offset.y = 1;
            videoTexture.rotation = 0;
            screenMaterial.map?.dispose();
            screenMaterial.map = videoTexture;
            screenMaterial.needsUpdate = true;
            if (shouldAnimate()) void videoElement!.play().catch(() => undefined);
          }, { once: true });
          videoElement.load();
        }
        root.classList.add('is-loaded');
        resize();
        startFrame();
      }, undefined, () => { root.classList.add('has-failed'); });
    };

    const loadObserver = new IntersectionObserver(([entry]) => {
      if (entry.isIntersecting) { loadModel(); loadObserver.disconnect(); }
    }, { rootMargin: '50px' });
    loadObserver.observe(root);

    const resizeObserver = new ResizeObserver(resize);
    resizeObserver.observe(root);

    root.addEventListener('pointermove', (event) => {
      const rect = root.getBoundingClientRect();
      pointerX = ((event.clientX - rect.left) / rect.width - 0.5) * 2;
      pointerY = -(((event.clientY - rect.top) / rect.height - 0.5) * 2);
    });
    root.addEventListener('pointerleave', () => { pointerX = 0; pointerY = 0; });

    const visibilityObserver = new IntersectionObserver(([entry]) => {
      isSceneVisible = entry.isIntersecting;
      if (shouldAnimate()) { startFrame(); if (videoTexture && videoElement) void videoElement.play().catch(() => undefined); }
      else { stopFrame(); videoElement?.pause(); }
    }, { threshold: 0.05 });
    visibilityObserver.observe(root);

    document.addEventListener('visibilitychange', () => {
      isPageVisible = !document.hidden;
      if (shouldAnimate()) { startFrame(); if (videoTexture && videoElement) void videoElement.play().catch(() => undefined); }
      else { stopFrame(); videoElement?.pause(); }
    });

    document.addEventListener('astro:before-swap', () => {
      stopFrame();
      resizeObserver.disconnect();
      visibilityObserver.disconnect();
      videoElement?.pause();
      videoTexture?.dispose();
      environmentMap.dispose();
      renderer.dispose();
    }, { once: true });
  });
</script>