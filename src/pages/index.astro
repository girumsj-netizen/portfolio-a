---
import Layout from '../layouts/Layout.astro';
const canonical = 'https://yourdomain.com';
---
<Layout title="Fast Portfolio Websites for Growing Brands" description="Clear fast websites for business owners who want more trust and better leads." canonical={canonical}>
  <section id="hero" class="showcase-hero pb-16 pt-10">
    <div class="grid gap-10 lg:grid-cols-[0.95fr_1.05fr] lg:items-start">
      <div class="hero-copy">
        <p class="text-xs font-mono uppercase tracking-widest text-zinc-500">[01 / WEBSITE BUILD]</p>
        <h1 class="mt-5 max-w-3xl text-5xl font-semibold tracking-tight leading-[1.02] text-white sm:text-6xl lg:text-6xl xl:text-[4.35rem]">I build fast websites that help good businesses look trusted and get better leads.</h1>
        <p class="mt-5 max-w-2xl text-lg tracking-tight text-zinc-300">Your site should load fast and explain your offer clearly. I design and build clean pages that make it easy for people to contact you.</p>
        <div class="mt-8 flex flex-col gap-4 sm:flex-row">
          <a href="#audit" class="inline-flex items-center justify-center rounded-full bg-accent px-8 py-4 text-base font-semibold text-black shadow-[0_0_0_rgba(0,179,126,0.35)] transition-all duration-300 ease-out hover:shadow-[0_0_40px_rgba(0,179,126,0.28)]">Get a Free 3-Minute Web Audit</a>
          <a href="#services" class="inline-flex items-center justify-center rounded-full border border-zinc-700 bg-[#111113] px-8 py-4 text-base font-semibold text-zinc-200 transition-all duration-300 ease-out hover:border-zinc-600 hover:text-white">See Services and Pricing</a>
        </div>

        <div class="mt-8 max-w-xl rounded-[2rem] border border-zinc-800/60 bg-[#141417] p-5 shadow-soft">
          <article class="grid gap-4">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
              <span class="rounded-full bg-accent/10 px-3 py-1 text-xs uppercase tracking-[0.32em] text-accent">Performance</span>
              <p class="text-sm text-zinc-400">Fast pages with clear structure and search basics built in.</p>
            </div>
            <div class="grid gap-4 sm:grid-cols-3">
              <div class="rounded-3xl bg-[#0f0f12] p-5 text-center">
                <span class="block text-sm uppercase tracking-[0.28em] text-zinc-500">LCP</span>
                <strong class="mt-3 block text-3xl font-semibold text-white">1.8s</strong>
              </div>
              <div class="rounded-3xl bg-[#0f0f12] p-5 text-center">
                <span class="block text-sm uppercase tracking-[0.28em] text-zinc-500">CLS</span>
                <strong class="mt-3 block text-3xl font-semibold text-white">0.05</strong>
              </div>
              <div class="rounded-3xl bg-[#0f0f12] p-5 text-center">
                <span class="block text-sm uppercase tracking-[0.28em] text-zinc-500">SEO</span>
                <strong class="mt-3 block text-3xl font-semibold text-white">Ready</strong>
              </div>
            </div>
          </article>
        </div>
      </div>

      <div class="hero-visual" aria-label="Interactive 3D iPhone portfolio preview">
        <div class="iphone-scene" data-iphone-scene data-model-src="/assets/models/iphone.gltf">
          <canvas aria-hidden="true"></canvas>
          <div class="iphone-fallback">
            <div class="fallback-phone">
              <span></span>
              <strong>1.8s</strong>
              <p>Fast clear and ready.</p>
            </div>
          </div>
        </div>
        <div class="hero-visual-caption">
          <span>Interactive device preview</span>
          <strong>Built for mobile buyers</strong>
        </div>
      </div>
    </div>
  </section>

  <section id="work" class="space-y-12 pb-20">
    <div class="space-y-4">
      <p class="text-xs font-mono uppercase tracking-widest text-zinc-500">[02 / THE PROBLEM]</p>
      <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">A slow or confusing website makes people leave before they trust you.</h2>
      <p class="max-w-3xl text-base leading-8 text-zinc-400">Many sites look nice but they do not explain the offer well. I build pages that feel professional and help visitors know what to do next.</p>
    </div>

    <div class="grid gap-6 lg:grid-cols-[1fr_0.9fr]">
      <article class="rounded-2xl bg-[#141417] border border-zinc-800/60 p-8 transition-all duration-300 hover:border-zinc-700/80">
        <p class="text-xs font-mono uppercase tracking-widest text-zinc-500">Problem</p>
        <h3 class="mt-4 text-2xl font-semibold tracking-tight text-white">A pretty site is not enough.</h3>
        <p class="mt-4 text-zinc-400">If your site is slow or unclear then visitors may leave before they understand your value. That means fewer calls and fewer strong leads.</p>
      </article>
      <article class="rounded-2xl bg-[#141417] border border-zinc-800/60 p-8 transition-all duration-300 hover:border-zinc-700/80">
        <p class="text-xs font-mono uppercase tracking-widest text-zinc-500">Solution</p>
        <h3 class="mt-4 text-2xl font-semibold tracking-tight text-white">A clear site makes the next step easy.</h3>
        <p class="mt-4 text-zinc-400">I build clean pages with fast loading and simple sections. Each part helps people understand your service and reach out with confidence.</p>
      </article>
    </div>
  </section>

  <section class="space-y-10 pb-20">
    <div class="space-y-4">
      <p class="text-xs font-mono uppercase tracking-widest text-zinc-500">[03 / CASE STUDIES]</p>
      <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">Recent website work with a clear business goal.</h2>
      <p class="max-w-3xl text-base leading-8 text-zinc-400">Each project shows the problem and the result in simple terms. The goal is always a site that is easy to use and easy to trust.</p>
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-3">
      <article class="md:col-span-2 rounded-2xl bg-[#141417] border border-zinc-800/60 p-8 transition-all duration-300 hover:border-zinc-700/80">
        <p class="text-xs font-mono uppercase tracking-widest text-zinc-500">Project Showcase</p>
        <h3 class="mt-4 text-2xl font-semibold tracking-tight text-white">Nova Flow desktop and mobile preview.</h3>
        <div class="mt-6 space-y-4 text-zinc-400">
          <div>
            <p class="font-semibold text-white">The UI</p>
            <p>Clean dashboard screens shown on desktop and mobile.</p>
          </div>
          <div>
            <p class="font-semibold text-white">The experience</p>
            <p>A sharp preview that feels modern and loads smoothly.</p>
          </div>
          <div>
            <p class="font-semibold text-white">Why it matters</p>
            <p>It helps buyers understand the product quickly and trust the brand.</p>
          </div>
        </div>
        <figure class="mt-8 overflow-hidden rounded-3xl border border-zinc-800/60 bg-[#0b0b0e]">
          <img src="/case-study-1.svg" alt="Nova Flow dashboard preview with desktop and mobile interface panels" class="aspect-[16/9] w-full object-cover" loading="lazy" />
        </figure>
      </article>

      <article class="rounded-2xl bg-[#141417] border border-zinc-800/60 p-8 transition-all duration-300 hover:border-zinc-700/80">
        <p class="text-xs font-mono uppercase tracking-widest text-zinc-500">Case Study 02</p>
        <h3 class="mt-4 text-2xl font-semibold tracking-tight text-white">Lead generation page for a consulting brand.</h3>
        <div class="mt-6 space-y-4 text-zinc-400">
          <p>Built a fast page with clear copy and a simple form that helps serious buyers get in touch.</p>
        </div>
        <figure class="mt-8 overflow-hidden rounded-3xl border border-zinc-800/60 bg-[#0b0b0e]">
          <img src="/case-study-2.svg" alt="Secure analytics and lead pipeline view" class="aspect-[4/3] w-full object-cover" loading="lazy" />
        </figure>
      </article>

      <article class="rounded-2xl bg-[#141417] border border-zinc-800/60 p-8 transition-all duration-300 hover:border-zinc-700/80">
        <p class="text-xs font-mono uppercase tracking-widest text-zinc-500">Case Study 03</p>
        <h3 class="mt-4 text-2xl font-semibold tracking-tight text-white">Launch page for a software product.</h3>
        <div class="mt-6 space-y-4 text-zinc-400">
          <p>Created a simple page that explains the offer and guides visitors toward the next step.</p>
        </div>
        <figure class="mt-8 overflow-hidden rounded-3xl border border-zinc-800/60 bg-[#0b0b0e]">
          <img src="/case-study-3.svg" alt="Visual outline of a premium productized service offering" class="aspect-[4/3] w-full object-cover" loading="lazy" />
        </figure>
      </article>
    </div>
  </section>

  <section id="services" class="space-y-10 pb-20">
    <div class="space-y-4">
      <p class="text-xs font-mono uppercase tracking-widest text-zinc-500">[04 / SERVICES]</p>
      <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">Simple website packages with clear pricing.</h2>
      <p class="max-w-3xl text-base leading-8 text-zinc-400">Choose the package that fits your goal. Each one includes a clear process and a polished final site.</p>
    </div>

    <div class="grid gap-6 lg:grid-cols-3">
      <article class="rounded-2xl bg-[#141417] border border-zinc-800/60 p-8 transition-all duration-300 hover:border-zinc-700/80">
        <p class="text-xs font-mono uppercase tracking-widest text-zinc-500">Tier</p>
        <h3 class="mt-4 text-2xl font-semibold tracking-tight text-white">Landing Page Accelerator</h3>
        <p class="mt-4 text-zinc-400">A focused landing page for one offer and one clear action.</p>
        <div class="mt-6 space-y-3 text-white">
          <p class="text-3xl font-semibold">$4500</p>
          <p class="text-sm text-zinc-500">Includes the main section and proof points and a contact path.</p>
        </div>
        <a href="#audit" class="mt-8 inline-flex w-full items-center justify-center rounded-full bg-accent px-6 py-3 text-sm font-semibold text-black transition-all duration-300 ease-out hover:shadow-[0_0_40px_rgba(0,179,126,0.2)]">Request this tier</a>
      </article>

      <article class="rounded-2xl bg-[#141417] border border-zinc-800/60 p-8 transition-all duration-300 hover:border-zinc-700/80">
        <p class="text-xs font-mono uppercase tracking-widest text-zinc-500">Tier</p>
        <h3 class="mt-4 text-2xl font-semibold tracking-tight text-white">Business Engine Launch</h3>
        <p class="mt-4 text-zinc-400">A full website for a business that needs trust and clear service pages.</p>
        <div class="mt-6 space-y-3 text-white">
          <p class="text-3xl font-semibold">$9500</p>
          <p class="text-sm text-zinc-500">Includes core pages and clear copy and launch support.</p>
        </div>
        <a href="#audit" class="mt-8 inline-flex w-full items-center justify-center rounded-full bg-accent px-6 py-3 text-sm font-semibold text-black transition-all duration-300 ease-out hover:shadow-[0_0_40px_rgba(0,179,126,0.2)]">Start your project</a>
      </article>

      <article class="rounded-2xl bg-[#141417] border border-zinc-800/60 p-8 transition-all duration-300 hover:border-zinc-700/80">
        <p class="text-xs font-mono uppercase tracking-widest text-zinc-500">Tier</p>
        <h3 class="mt-4 text-2xl font-semibold tracking-tight text-white">Conversion Growth Suite</h3>
        <p class="mt-4 text-zinc-400">A growth package for teams that want steady improvements after launch.</p>
        <div class="mt-6 space-y-3 text-white">
          <p class="text-3xl font-semibold">$14500</p>
          <p class="text-sm text-zinc-500">Best for teams that want better pages and better results over time.</p>
        </div>
        <a href="#audit" class="mt-8 inline-flex w-full items-center justify-center rounded-full bg-accent px-6 py-3 text-sm font-semibold text-black transition-all duration-300 ease-out hover:shadow-[0_0_40px_rgba(0,179,126,0.2)]">Book the suite</a>
      </article>
    </div>
  </section>

  <section id="audit" class="pb-20">
    <div class="space-y-4">
      <p class="text-xs font-mono uppercase tracking-widest text-zinc-500">[05 / AUDIT]</p>
      <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">Get a quick review of your current website.</h2>
      <p class="max-w-3xl text-base leading-8 text-zinc-400">Send your site link and I will point out what is slow or unclear. You will get simple ideas you can use right away.</p>
    </div>

    <div class="mt-10 rounded-[2rem] border border-zinc-800/60 bg-[#141417] p-8 shadow-soft">
      <form class="grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
        <div class="space-y-6">
          <label class="block text-sm font-semibold tracking-tight text-zinc-100">
            Name
            <input type="text" name="name" required class="mt-3 w-full rounded-3xl border border-zinc-800/60 bg-[#0d0d11] px-5 py-4 text-sm text-zinc-100 outline-none transition-all duration-300 focus:border-accent/70 focus:ring-2 focus:ring-accent/10" />
          </label>
          <label class="block text-sm font-semibold tracking-tight text-zinc-100">
            Business email
            <input type="email" name="email" required class="mt-3 w-full rounded-3xl border border-zinc-800/60 bg-[#0d0d11] px-5 py-4 text-sm text-zinc-100 outline-none transition-all duration-300 focus:border-accent/70 focus:ring-2 focus:ring-accent/10" />
          </label>
          <label class="block text-sm font-semibold tracking-tight text-zinc-100">
            Current website URL
            <input type="url" name="website" required placeholder="https://" class="mt-3 w-full rounded-3xl border border-zinc-800/60 bg-[#0d0d11] px-5 py-4 text-sm text-zinc-100 outline-none transition-all duration-300 focus:border-accent/70 focus:ring-2 focus:ring-accent/10" />
          </label>
        </div>

        <div class="space-y-6">
          <label class="block text-sm font-semibold tracking-tight text-zinc-100">
            Quick brief
            <textarea name="brief" rows="8" required class="mt-3 w-full rounded-3xl border border-zinc-800/60 bg-[#0d0d11] px-5 py-4 text-sm text-zinc-100 outline-none transition-all duration-300 focus:border-accent/70 focus:ring-2 focus:ring-accent/10"></textarea>
          </label>
          <div class="rounded-3xl bg-[#0f0f12] p-5 text-sm text-zinc-400">
            <p class="font-medium text-zinc-200">Privacy first</p>
            <p class="mt-2">No extra tracking is added by default. This form is only for contact.</p>
          </div>
          <button type="submit" class="inline-flex w-full items-center justify-center rounded-full bg-accent px-6 py-4 text-base font-semibold text-black transition-all duration-300 ease-out hover:shadow-[0_0_40px_rgba(0,179,126,0.2)]">Request a personalized audit</button>
        </div>
      </form>
    </div>
  </section>
</Layout>

<script>
  import * as THREE from 'three';
  import { GLTFLoader } from 'three/examples/jsm/loaders/GLTFLoader.js';

  const sceneRoots = document.querySelectorAll<HTMLElement>('[data-iphone-scene]');

  sceneRoots.forEach((root) => {
    const canvas = root.querySelector('canvas');
    const modelSrc = root.dataset.modelSrc;

    if (!canvas || !modelSrc) {
      return;
    }

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(34, 1, 0.1, 100);
    const renderer = new THREE.WebGLRenderer({
      canvas,
      alpha: true,
      antialias: true,
      powerPreference: 'high-performance'
    });

    renderer.outputColorSpace = THREE.SRGBColorSpace;
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2.5));

    const makeScreenTexture = (source: HTMLImageElement) => {
      const safeTop = Math.round(source.height * 0.04);
      const screenScale = 1.08;
      const canvasTexture = document.createElement('canvas');
      canvasTexture.width = source.width;
      canvasTexture.height = source.height;

      const context = canvasTexture.getContext('2d');

      if (context) {
        const scaledWidth = source.width * screenScale;
        const scaledHeight = source.height * screenScale;
        const offsetX = (source.width - scaledWidth) / 2;

        context.fillStyle = '#031719';
        context.fillRect(0, 0, canvasTexture.width, canvasTexture.height);
        context.drawImage(source, offsetX, safeTop, scaledWidth, scaledHeight);
      }

      const texture = new THREE.CanvasTexture(canvasTexture);
      texture.colorSpace = THREE.SRGBColorSpace;
      texture.flipY = false;
      texture.minFilter = THREE.LinearFilter;
      texture.magFilter = THREE.LinearFilter;
      texture.generateMipmaps = false;
      texture.wrapS = THREE.RepeatWrapping;
      texture.center.set(0.5, 0.5);
      texture.rotation = Math.PI;
      texture.repeat.x = -1;
      texture.anisotropy = renderer.capabilities.getMaxAnisotropy();

      return texture;
    };

    const screenImage = new Image();
    screenImage.src = '/assets/pictures/novaflow-screen.png';
    const screenMaterial = new THREE.MeshBasicMaterial({
      color: 0xffffff,
      side: THREE.DoubleSide,
      toneMapped: false
    });
    const bodyMaterial = new THREE.MeshStandardMaterial({
      color: 0x111417,
      metalness: 0.85,
      roughness: 0.28,
      envMapIntensity: 0.7
    });
    const backMaterial = new THREE.MeshStandardMaterial({
      color: 0x07090c,
      metalness: 0.55,
      roughness: 0.42,
      envMapIntensity: 0.45
    });
    const blackGlassMaterial = new THREE.MeshBasicMaterial({
      color: 0x020305,
      side: THREE.DoubleSide,
      toneMapped: false
    });

    screenImage.addEventListener('load', () => {
      screenMaterial.map = makeScreenTexture(screenImage);
      screenMaterial.needsUpdate = true;
    });

    const keyLight = new THREE.DirectionalLight(0xffffff, 3.2);
    keyLight.position.set(3.5, 4, 5);
    scene.add(keyLight);
    scene.add(new THREE.HemisphereLight(0xb9fff1, 0x0a1020, 2.2));

    const fillLight = new THREE.PointLight(0x00b37e, 18, 12);
    fillLight.position.set(-3, 1.5, 3);
    scene.add(fillLight);

    const phoneGroup = new THREE.Group();
    phoneGroup.rotation.set(-0.08, -0.35, 0.03);
    scene.add(phoneGroup);

    const loader = new GLTFLoader();
    let model: THREE.Object3D | null = null;
    let animationFrame = 0;
    let pointerX = 0;
    let pointerY = 0;

    const resize = () => {
      const { width, height } = root.getBoundingClientRect();
      renderer.setSize(width, height, false);
      camera.aspect = width / Math.max(height, 1);
      camera.position.set(0, 0.05, width < 560 ? 7 : 6.25);
      camera.updateProjectionMatrix();
    };

    const frame = () => {
      animationFrame = window.requestAnimationFrame(frame);
      const time = performance.now() * 0.001;

      phoneGroup.rotation.y += ((-0.35 + pointerX * 0.22) - phoneGroup.rotation.y) * 0.05;
      phoneGroup.rotation.x += ((-0.08 + pointerY * 0.12) - phoneGroup.rotation.x) * 0.05;
      phoneGroup.position.y = 0.28 + Math.sin(time * 1.35) * 0.06;

      renderer.render(scene, camera);
    };

    root.addEventListener('pointermove', (event) => {
      const rect = root.getBoundingClientRect();
      pointerX = ((event.clientX - rect.left) / rect.width - 0.5) * 2;
      pointerY = -(((event.clientY - rect.top) / rect.height - 0.5) * 2);
    });

    root.addEventListener('pointerleave', () => {
      pointerX = 0;
      pointerY = 0;
    });

    loader.load(
      modelSrc,
      (gltf) => {
        model = gltf.scene;

        model.traverse((object) => {
          if (object.name.toLowerCase() === 'floor') {
            object.visible = false;
          }

          const meshCandidate = object as THREE.Object3D & { isMesh?: boolean; material?: THREE.Material | THREE.Material[] };
          const meshName = object.name.toLowerCase();

          if (meshCandidate.isMesh && meshName === 'screen') {
            meshCandidate.material = screenMaterial;
          }

          if (
            meshCandidate.isMesh &&
            ['metal border', 'body-screen', 'button'].includes(meshName)
          ) {
            meshCandidate.material = bodyMaterial;
          }

          if (meshCandidate.isMesh && meshName === 'back side') {
            meshCandidate.material = backMaterial;
          }

          if (meshCandidate.isMesh && meshName === 'screen border') {
            meshCandidate.material = blackGlassMaterial;
          }

          if (
            meshCandidate.isMesh &&
            ['rectangle', 'rectangle_5', 'ellipse', 'ellipse_2'].includes(meshName)
          ) {
            meshCandidate.material = blackGlassMaterial;
          }
        });

        const box = new THREE.Box3();
        model.traverse((object) => {
          const meshCandidate = object as THREE.Object3D & { isMesh?: boolean };

          if (meshCandidate.isMesh && object.visible) {
            box.expandByObject(object);
          }
        });

        if (box.isEmpty()) {
          box.setFromObject(model);
        }

        const size = box.getSize(new THREE.Vector3());
        const center = box.getCenter(new THREE.Vector3());
        const maxAxis = Math.max(size.x, size.y, size.z);
        const scale = 3.05 / Math.max(maxAxis, 1);

        model.scale.setScalar(scale);
        model.position.set(-center.x * scale, -center.y * scale, -center.z * scale);
        phoneGroup.add(model);
        root.classList.add('is-loaded');
      },
      undefined,
      () => {
        root.classList.add('has-failed');
      }
    );

    resize();
    frame();

    const observer = new ResizeObserver(resize);
    observer.observe(root);

    document.addEventListener('astro:before-swap', () => {
      window.cancelAnimationFrame(animationFrame);
      observer.disconnect();
      renderer.dispose();
    }, { once: true });
  });
</script>

