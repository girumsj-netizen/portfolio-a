      const tuneLaptopMaterial = (material: THREE.Material) => {
        const tunedMaterial = material.clone();
        const standardMaterial = tunedMaterial as THREE.MeshStandardMaterial;

        if ('envMapIntensity' in standardMaterial) standardMaterial.envMapIntensity = 0.95;
        if ('roughness' in standardMaterial) standardMaterial.roughness = Math.max(standardMaterial.roughness ?? 0.35, 0.34);
        if ('metalness' in standardMaterial) standardMaterial.metalness = Math.max(standardMaterial.metalness ?? 0.2, 0.32);
        if ('color' in standardMaterial && standardMaterial.color instanceof THREE.Color) {
          const brightness = Math.max(standardMaterial.color.r, standardMaterial.color.g, standardMaterial.color.b);
          if (brightness > 0.72 && !standardMaterial.map) {
            standardMaterial.color.set(0x2b3037);
          } else {
            standardMaterial.color.lerp(new THREE.Color(0x1b2026), 0.18);
          }
        }

        return tunedMaterial;
      };

      const resize = () => {
        const { width, height } = root.getBoundingClientRect();
        const isCompact = width < 640;
        renderer.setSize(width, height, false);
        camera.aspect = width / Math.max(height, 1);
        camera.fov = isCompact ? 40 : 34;
        camera.position.set(isCompact ? -0.56 : -0.78, isCompact ? 0.52 : 0.58, isCompact ? 2.95 : 3.45);
        camera.lookAt(isCompact ? -0.08 : -0.14, isCompact ? 0.2 : 0.18, 0.0);
        camera.updateProjectionMatrix();
        laptopGroup.position.x = isCompact ? -0.02 : -0.1;
      };

      const frame = () => {
        if (!shouldAnimate()) {
          isAnimating = false;
          return;
        }

        animationFrame = window.requestAnimationFrame(frame);
        const time = performance.now() * 0.001;
        const targetRotationY = laptopBaseRotationY + pointerX * 0.018 + Math.sin(time * 0.32) * 0.006;
        const targetRotationX = laptopBaseRotationX + pointerY * 0.01 + Math.sin(time * 0.28) * 0.004;
        laptopGroup.rotation.y += (targetRotationY - laptopGroup.rotation.y) * 0.04;
        laptopGroup.rotation.x += (targetRotationX - laptopGroup.rotation.x) * 0.04;
        laptopGroup.position.y = laptopBaseY + Math.sin(time * 0.28) * 0.004;
        renderer.render(scene, camera);
      };

      const startFrame = () => {
        if (isAnimating || !shouldAnimate()) return;
        isAnimating = true;
        animationFrame = window.requestAnimationFrame(frame);
      };

      const stopFrame = () => {
        if (!isAnimating) return;
        window.cancelAnimationFrame(animationFrame);
        isAnimating = false;
      };

      const loader = new GLTFLoader();
      loader.load(
        modelSrc,
        (gltf) => {
          const model = gltf.scene;
          model.updateMatrixWorld(true);

          videoElement = document.createElement('video');
          videoElement.src = '/assets/videos/laptop-screen.mp4';
          videoElement.muted = true;
          videoElement.loop = true;
          videoElement.playsInline = true;
          videoElement.preload = 'auto';

          model.traverse((object) => {
            const meshCandidate = object as THREE.Object3D & { isMesh?: boolean; material?: THREE.Material | THREE.Material[] };

            if (!meshCandidate.isMesh) return;

            const normalizedName = object.name.toLowerCase().replace(/[\s-]+/g, '_');
            const meshBox = new THREE.Box3().setFromObject(object);
            const meshSize = meshBox.getSize(new THREE.Vector3());
            const meshCenter = meshBox.getCenter(new THREE.Vector3());
            const largestSide = Math.max(meshSize.x, meshSize.y, meshSize.z);
            const isOutsideLaptopCluster =
              largestSide > 8 ||
              Math.abs(meshCenter.x) > 7 ||
              meshCenter.y < 2.5 ||
              meshCenter.y > 6.5 ||
              meshCenter.z < -3 ||
              meshCenter.z > 5;

            if (isOutsideLaptopCluster) {
              object.visible = false;
              return;
            }

            meshCandidate.castShadow = true;
            meshCandidate.receiveShadow = true;

            if (
              normalizedName.includes('screen') ||
              normalizedName.includes('display') ||
              object.parent?.name.toLowerCase().includes('change_image_here')
            ) {
              meshCandidate.castShadow = false;
              meshCandidate.receiveShadow = false;
              meshCandidate.material = screenMaterial;
              screenTextureMaterial = screenMaterial;
              return;
            }

            meshCandidate.material = Array.isArray(meshCandidate.material)
              ? meshCandidate.material.map(tuneLaptopMaterial)
              : tuneLaptopMaterial(meshCandidate.material);
          });

          const box = new THREE.Box3();
          model.traverse((object) => {
            const meshCandidate = object as THREE.Object3D & { isMesh?: boolean };
            if (meshCandidate.isMesh && object.visible) box.expandByObject(object);
          });
          const size = box.getSize(new THREE.Vector3());
          const center = box.getCenter(new THREE.Vector3());
          const maxAxis = Math.max(size.x, size.y, size.z);
          const modelScale = 3.35 / Math.max(maxAxis, 1);

          model.scale.setScalar(modelScale);
          model.position.set(-center.x * modelScale, -center.y * modelScale, -center.z * modelScale);
          laptopGroup.add(model);
          laptopBaseRotationX = -0.12;
          laptopBaseRotationY = -0.46;
          laptopBaseY = -0.08;
          laptopGroup.rotation.set(laptopBaseRotationX, laptopBaseRotationY, 0.01);
          laptopGroup.position.set(-0.1, laptopBaseY, 0.1);

           const contactShadow = new THREE.Mesh(
             new THREE.CircleGeometry(2.2, 64),
             new THREE.ShadowMaterial({ color: 0x000000, opacity: 0.45 })
           );
           contactShadow.rotation.x = -Math.PI / 2;
           contactShadow.position.set(-0.06, -1.0, 0.28);
           contactShadow.scale.set(1.35, 0.5, 1);
           contactShadow.receiveShadow = true;
           scene.add(contactShadow);

          videoElement.addEventListener('loadeddata', () => {
            videoTexture = new THREE.VideoTexture(videoElement!);
            videoTexture.colorSpace = THREE.SRGBColorSpace;
            videoTexture.flipY = false;
            videoTexture.minFilter = THREE.LinearFilter;
            videoTexture.magFilter = THREE.LinearFilter;
            videoTexture.generateMipmaps = false;
            videoTexture.wrapS = THREE.RepeatWrapping;
            videoTexture.wrapT = THREE.RepeatWrapping;
            videoTexture.repeat.set(1, -1);
            videoTexture.offset.set(0, 1);
            videoTexture.rotation = 0;

            if (screenTextureMaterial === screenMaterial) {
              screenMaterial.map?.dispose();
              screenMaterial.map = videoTexture;
              screenMaterial.needsUpdate = true;
            }

            if (shouldAnimate()) {
              void videoElement!.play().catch(() => undefined);
            }
          }, { once: true });

          videoElement.load();
          root.classList.add('is-loaded');
          resize();
          startFrame();
        },
        undefined,
        () => {
          root.classList.add('has-failed');
        }
      );

      const resizeObserver = new ResizeObserver(resize);
      resizeObserver.observe(root);

      root.addEventListener('pointermove', (event) => {
        const rect = root.getBoundingClientRect();
        pointerX = ((event.clientX - rect.left) / rect.width - 0.5) * 2;
        pointerY = -(((event.clientY - rect.top) / rect.height - 0.5) * 2);
      });

      root.addEventListener('pointerleave', () => {
        pointerX = 0;
        pointerY = 0;
      });

      const visibilityObserver = new IntersectionObserver(([entry]) => {
        isSceneVisible = entry.isIntersecting;
        if (shouldAnimate()) {
          startFrame();
          if (videoTexture && videoElement) void videoElement.play().catch(() => undefined);
        } else {
          stopFrame();
          videoElement?.pause();
        }
      }, { threshold: 0.05 });
      visibilityObserver.observe(root);

      document.addEventListener('visibilitychange', () => {
        isPageVisible = !document.hidden;
        if (shouldAnimate()) {
          startFrame();
          if (videoTexture && videoElement) void videoElement.play().catch(() => undefined);
        } else {
          stopFrame();
          videoElement?.pause();
        }
      });

      document.addEventListener('astro:before-swap', () => {
        stopFrame();
        resizeObserver.disconnect();
        visibilityObserver.disconnect();
        videoElement?.pause();
        videoTexture?.dispose();
        environmentMap.dispose();
        renderer.dispose();
      }, { once: true });
    });
  });
</script>

