---
import Layout from '../layouts/Layout.astro';
const canonical = 'https://yourdomain.com';
---

<Layout title="Polaris Studios — Full-Service Creative Agency & Web Development" description="From premium logos and visual branding to high-performance front-ends and scalable back-end architecture, we build endless software solutions tailored to elevate your digital presence." canonical={canonical}>

  <!-- ===== TABBED INTERFACE ===== -->
  <div id="app-root" class="relative min-h-screen">

    <!-- Tab bar removed — tabs now live inside the navbar -->

    <!-- ===== TAB PANELS ===== -->

    <!-- TAB: STUDIO (Hero + Process) -->
    <div id="panel-studio" class="tab-panel active is-active space-y-12 pb-12">
      <section class="showcase-hero">
        <div class="grid gap-6 sm:gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
          <div class="hero-copy">
            <p class="text-[11px] sm:text-xs font-mono uppercase tracking-widest text-accent">[ / CREATIVE AGENCY]</p>
            <h1 class="mt-5 sm:mt-8 max-w-3xl text-2xl sm:text-4xl lg:text-5xl font-semibold tracking-tight leading-[1.08] text-white">
              We build stunning websites, design professional logos, and develop custom software apps for your business.
            </h1>
            <p class="mt-5 sm:mt-8 max-w-2xl text-sm sm:text-base lg:text-lg leading-relaxed text-zinc-300">
              From premium logos and visual branding to high-performance front-ends and scalable back-end architecture, we build endless software solutions tailored to elevate your digital presence.
            </p>
            <div class="mt-6 sm:mt-10 flex flex-col gap-3 sm:gap-4 sm:flex-row">
              <button data-tab-target="work" class="inline-flex items-center justify-center rounded-full bg-accent px-5 py-3 sm:px-8 sm:py-4 text-sm sm:text-base font-semibold text-black shadow-[0_0_0_rgba(0,179,126,0.35)] transition-all duration-300 ease-out hover:shadow-[0_0_40px_rgba(0,179,126,0.28)]">View Our Work</button>
              <button data-tab-target="contact" class="inline-flex items-center justify-center rounded-full border border-zinc-700 bg-[#111113] px-5 py-3 sm:px-8 sm:py-4 text-sm sm:text-base font-semibold text-zinc-200 transition-all duration-300 ease-out hover:border-zinc-600 hover:text-white">Start a Project</button>
            </div>

            <div class="mt-6 sm:mt-10 max-w-xl rounded-[2rem] border border-zinc-800/60 bg-[#141417] p-5 sm:p-7 shadow-soft">
              <article class="grid gap-5">
                <div class="flex items-center gap-4">
                  <span class="shrink-0 rounded-full bg-accent/10 px-4 py-1.5 text-[11px] sm:text-xs font-semibold uppercase tracking-[0.2em] text-accent">What we deliver</span>
                  <p class="text-xs sm:text-sm leading-relaxed text-zinc-400">Branding, UI design, development, and launch — crafted as one seamless experience.</p>
                </div>
                <div class="grid grid-cols-3 gap-2.5 sm:gap-3">
                  <div class="group rounded-2xl bg-[#0f0f12] border border-zinc-800/40 p-4 sm:p-5 text-center transition-all duration-300 hover:border-zinc-700/60">
                    <span class="block text-[10px] sm:text-xs font-medium uppercase tracking-[0.22em] text-accent">Identity</span>
                    <strong class="mt-2.5 block text-lg sm:text-xl lg:text-2xl font-semibold tracking-tight text-white">Branding</strong>
                  </div>
                  <div class="group rounded-2xl bg-[#0f0f12] border border-zinc-800/40 p-4 sm:p-5 text-center transition-all duration-300 hover:border-zinc-700/60">
                    <span class="block text-[10px] sm:text-xs font-medium uppercase tracking-[0.22em] text-accent">Interface</span>
                    <strong class="mt-2.5 block text-lg sm:text-xl lg:text-2xl font-semibold tracking-tight text-white">Websites</strong>
                  </div>
                  <div class="group rounded-2xl bg-[#0f0f12] border border-zinc-800/40 p-4 sm:p-5 text-center transition-all duration-300 hover:border-zinc-700/60">
                    <span class="block text-[10px] sm:text-xs font-medium uppercase tracking-[0.22em] text-accent">Systems</span>
                    <strong class="mt-2.5 block text-lg sm:text-xl lg:text-2xl font-semibold tracking-tight text-white">Apps</strong>
                  </div>
                </div>
              </article>
            </div>
          </div>

          <div class="hero-visual" aria-label="Interactive 3D device preview">
            <!-- Device toggle -->
            <div class="device-toggle" id="hero-device-toggle">
              <button data-device="iphone" class="active" aria-label="Show phone model">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="5" y="2" width="14" height="20" rx="2" ry="2"/><line x1="12" y1="18" x2="12.01" y2="18"/></svg>
                <span>Phone</span>
              </button>
              <button data-device="laptop" aria-label="Show laptop model">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="2" y1="20" x2="22" y2="20"/></svg>
                <span>Laptop</span>
              </button>
            </div>

            <!-- iPhone scene (default) -->
            <div class="iphone-scene hero-device-scene active" data-device-scene="iphone" data-iphone-scene data-model-src="/assets/models/iphone.gltf">
              <canvas aria-hidden="true"></canvas>
              <div class="iphone-fallback">
                <div class="fallback-phone">
                  <span></span>
                  <strong>1.8s</strong>
                  <p>Fast, clear, and ready.</p>
                </div>
              </div>
            </div>

            <!-- Laptop scene (hidden) -->
            <div class="hero-device-scene" data-device-scene="laptop" style="display:none; position:absolute; inset:0; min-height:100%;">
              <div class="laptop-scene h-full w-full" data-laptop-scene data-model-src="/assets/models/macbook.glb">
                <canvas aria-hidden="true"></canvas>
              </div>
            </div>

            <div class="hero-visual-caption">
              <span>Interactive preview</span>
              <strong>The interfaces we build are compatible with multiple devices</strong>
            </div>
          </div>
        </div>
      </section>

      <!-- Process -->
      <section class="space-y-8">
        <div class="space-y-4">
          <p class="text-xs font-mono uppercase tracking-widest text-zinc-500">[ / OUR PROCESS]</p>
          <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">A straightforward process with no surprises.</h2>
        </div>
        <div class="grid gap-4 sm:gap-6 md:grid-cols-4">
          <article class="rounded-2xl bg-[#141417] border border-zinc-800/60 p-5 sm:p-6 transition-all duration-300 hover:border-zinc-700/80">
            <p class="text-xs font-mono uppercase tracking-widest text-accent">01</p>
            <h3 class="mt-4 text-lg font-semibold text-white">Discover</h3>
            <p class="mt-3 text-sm text-zinc-400">We learn about your brand, audience, goals, and competitive landscape to define the strategic direction.</p>
          </article>
          <article class="rounded-2xl bg-[#141417] border border-zinc-800/60 p-5 sm:p-6 transition-all duration-300 hover:border-zinc-700/80">
            <p class="text-xs font-mono uppercase tracking-widest text-accent">02</p>
            <h3 class="mt-4 text-lg font-semibold text-white">Define</h3>
            <p class="mt-3 text-sm text-zinc-400">We architect the page structure, user flows, messaging hierarchy, and conversion strategy.</p>
          </article>
          <article class="rounded-2xl bg-[#141417] border border-zinc-800/60 p-5 sm:p-6 transition-all duration-300 hover:border-zinc-700/80">
            <p class="text-xs font-mono uppercase tracking-widest text-accent">03</p>
            <h3 class="mt-4 text-lg font-semibold text-white">Create</h3>
            <p class="mt-3 text-sm text-zinc-400">We design and develop the full experience — from UI concepts to responsive, performance-optimized code.</p>
          </article>
          <article class="rounded-2xl bg-[#141417] border border-zinc-800/60 p-5 sm:p-6 transition-all duration-300 hover:border-zinc-700/80">
            <p class="text-xs font-mono uppercase tracking-widest text-accent">04</p>
            <h3 class="mt-4 text-lg font-semibold text-white">Launch</h3>
            <p class="mt-3 text-sm text-zinc-400">We deploy, monitor, and hand over a polished product with everything your team needs to maintain and grow.</p>
          </article>
        </div>
      </section>
    </div>

    <!-- TAB: WORK -->
    <div id="panel-work" class="tab-panel space-y-8 pb-12 hidden is-active">
      <!-- Work sub-tabs -->
      <div class="flex flex-wrap gap-2">
        <button data-subtab="websites" class="work-subtab-btn active px-5 py-2 rounded-full text-xs sm:text-sm font-medium transition-all duration-300 bg-zinc-800/30 text-zinc-400 hover:text-white border border-zinc-800/40 data-[active=true]:bg-accent/10 data-[active=true]:text-accent data-[active=true]:border-accent/30">
          Websites
        </button>
        <button data-subtab="branding" class="work-subtab-btn px-5 py-2 rounded-full text-xs sm:text-sm font-medium transition-all duration-300 bg-zinc-800/30 text-zinc-400 hover:text-white border border-zinc-800/40 data-[active=true]:bg-accent/10 data-[active=true]:text-accent data-[active=true]:border-accent/30">
          Branding
        </button>
        <button data-subtab="apps" class="work-subtab-btn px-5 py-2 rounded-full text-xs sm:text-sm font-medium transition-all duration-300 bg-zinc-800/30 text-zinc-400 hover:text-white border border-zinc-800/40 data-[active=true]:bg-accent/10 data-[active=true]:text-accent data-[active=true]:border-accent/30">
          Apps
        </button>
      </div>

      <!-- Websites sub-panel -->
      <div id="work-websites" class="work-subpanel active space-y-8">
        <!-- Nova Flow project -->
        <article class="rounded-2xl bg-[#141417] border border-zinc-800/60 p-5 sm:p-8 transition-all duration-300 hover:border-zinc-700/80">
          <p class="text-xs font-mono uppercase tracking-widest text-accent">SaaS Dashboard</p>
          <h3 class="mt-3 sm:mt-4 text-xl sm:text-2xl font-semibold tracking-tight text-white">Nova Flow — enterprise analytics interface.</h3>
          <div class="mt-4 sm:mt-6 grid gap-4 text-zinc-400 sm:grid-cols-3">
            <div>
              <p class="font-semibold text-white">Our goal</p>
              <p class="mt-2 text-sm sm:text-base">Transform a complex data platform into an intuitive, visually compelling dashboard that users trust at first glance.</p>
            </div>
            <div>
              <p class="font-semibold text-white">Our solution</p>
              <p class="mt-2 text-sm sm:text-base">We designed a clean desktop and mobile experience with strong contrast, clear data hierarchy, and seamless navigation.</p>
            </div>
            <div>
              <p class="font-semibold text-white">Result</p>
              <p class="mt-2 text-sm sm:text-base">A sharper product presence that helps buyers evaluate with confidence — even under time pressure.</p>
            </div>
          </div>
          <figure class="mt-6 sm:mt-8">
            <div class="relative aspect-[16/9] overflow-hidden rounded-3xl border border-zinc-800/60 bg-[radial-gradient(circle_at_30%_40%,rgba(0,179,126,0.18),transparent_52%),radial-gradient(circle_at_70%_20%,rgba(96,165,250,0.15),transparent_38%),#09131c] shadow-[0_32px_80px_rgba(0,0,0,0.5)]">
              <div class="iphone-scene" data-iphone-scene data-model-src="/assets/models/iphone.gltf" style="position:absolute;inset:0;min-height:100%;">
                <canvas aria-hidden="true"></canvas>
              </div>
            </div>
          </figure>
        </article>

        <!-- AETHER project -->
        <article class="rounded-2xl bg-gradient-to-br from-[#141417] to-[#111115] border border-zinc-800/60 p-5 sm:p-8 transition-all duration-300 hover:border-zinc-700/80">
          <div class="grid gap-6 lg:grid-cols-[0.78fr_1.22fr] lg:items-center">
            <div>
              <p class="text-xs font-mono uppercase tracking-widest text-accent">Premium Commerce</p>
              <h3 class="mt-3 sm:mt-4 text-xl sm:text-2xl font-semibold tracking-tight text-white">AETHER — luxury audio experience.</h3>
              <div class="mt-4 sm:mt-6 space-y-4 text-zinc-400">
                <div>
                  <p class="font-semibold text-white">Our vision</p>
                  <p class="mt-2 text-sm sm:text-base">We built a refined interface for high-end audio equipment that communicates craft, restraint, and uncompromising quality through every pixel.</p>
                </div>
                <div>
                  <p class="font-semibold text-white">What we delivered</p>
                  <p class="mt-2 text-sm sm:text-base">Immersive product presentation with clear visual hierarchy, premium motion design, and an interactive 3D product viewer that lets buyers explore from every angle.</p>
                </div>
              </div>
              <div class="mt-4 flex flex-wrap gap-2">
                <span class="rounded-full border border-zinc-700/60 bg-zinc-800/20 px-3 py-1 text-xs text-zinc-400">3D Integration</span>
                <span class="rounded-full border border-zinc-700/60 bg-zinc-800/20 px-3 py-1 text-xs text-zinc-400">Animation</span>
                <span class="rounded-full border border-zinc-700/60 bg-zinc-800/20 px-3 py-1 text-xs text-zinc-400">Luxury UI</span>
              </div>
            </div>
            <div class="relative min-h-56 overflow-hidden rounded-3xl border border-zinc-800/60 bg-[#0b0b0e] sm:h-80 md:h-96">
              <div class="laptop-scene h-full w-full" data-laptop-scene data-model-src="/assets/models/macbook.glb">
                <canvas aria-hidden="true"></canvas>
              </div>
            </div>
          </div>
        </article>
      </div>

      <!-- Branding sub-panel -->
      <div id="work-branding" class="work-subpanel space-y-6 hidden">
        <p class="text-xs font-mono uppercase tracking-widest text-accent">Brand Identity Showcase</p>
        <h3 class="text-xl sm:text-2xl font-semibold tracking-tight text-white">Visual brand systems we design.</h3>
        <div class="grid gap-4 sm:gap-6 md:grid-cols-3">
          <article class="rounded-2xl bg-[#141417] border border-zinc-800/60 p-5 sm:p-6 transition-all duration-300 hover:border-zinc-700/80">
            <div class="aspect-square rounded-xl bg-[#0b0b0e] flex items-center justify-center mb-4">
              <span class="text-4xl font-bold text-accent/40">L</span>
            </div>
            <h4 class="text-sm font-semibold text-white">Logo Concepts</h4>
            <p class="mt-2 text-xs text-zinc-400">Custom wordmarks, symbols, and combination marks tailored to your brand identity.</p>
          </article>
          <article class="rounded-2xl bg-[#141417] border border-zinc-800/60 p-5 sm:p-6 transition-all duration-300 hover:border-zinc-700/80">
            <div class="aspect-square rounded-xl bg-[#0b0b0e] flex items-center justify-center mb-4">
              <div class="flex gap-2">
                <span class="w-6 h-6 rounded-full bg-accent"></span>
                <span class="w-6 h-6 rounded-full bg-blue-500"></span>
                <span class="w-6 h-6 rounded-full bg-amber-400"></span>
              </div>
            </div>
            <h4 class="text-sm font-semibold text-white">Color & Typography</h4>
            <p class="mt-2 text-xs text-zinc-400">Comprehensive palettes, font pairings, and design tokens that define your brand voice.</p>
          </article>
          <article class="rounded-2xl bg-[#141417] border border-zinc-800/60 p-5 sm:p-6 transition-all duration-300 hover:border-zinc-700/80">
            <div class="aspect-square rounded-xl bg-[#0b0b0e] flex items-center justify-center mb-4">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="-20 0 200 40" fill="none" class="h-11 w-auto">
                <rect width="40" height="40" rx="8" fill="#2563EB"/>
                <g transform="translate(8, 4) scale(1.333)">
                  <g transform="translate(-2.8, 0)">
                    <circle cx="12" cy="8" r="6" fill="none" stroke="white" stroke-width="1.5"/>
                    <path d="m15.477 12.89 1.515 8.526a.5.5 0 0 1-.81.47l-3.58-2.687a1 1 0 0 0-1.197 0l-3.586 2.686a.5.5 0 0 1-.81-.469l1.514-8.526" fill="none" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                  </g>
                </g>
                <text x="52" y="26" font-family="system-ui, -apple-system, sans-serif" font-size="18" font-weight="bold" fill="#111827">CertPlatform</text>
              </svg>
            </div>
            <h4 class="text-sm font-semibold text-white">CertPlatform Logo</h4>
            <p class="mt-2 text-xs text-zinc-400">A clean, simple shield mark with a minimal figure — designed for instant recognition across digital and print.</p>
          </article>
          <article class="rounded-2xl bg-[#141417] border border-zinc-800/60 p-5 sm:p-6 transition-all duration-300 hover:border-zinc-700/80">
            <div class="aspect-square rounded-xl bg-[#0b0b0e] flex items-center justify-center mb-4">
              <div class="grid grid-cols-2 gap-1">
                <span class="w-5 h-5 rounded bg-zinc-700"></span>
                <span class="w-5 h-5 rounded bg-zinc-700"></span>
                <span class="w-5 h-5 rounded bg-zinc-700"></span>
                <span class="w-5 h-5 rounded bg-zinc-700"></span>
              </div>
            </div>
            <h4 class="text-sm font-semibold text-white">Brand Applications</h4>
            <p class="mt-2 text-xs text-zinc-400">Stationery, packaging, brochures, and full corporate identity layouts.</p>
          </article>
        </div>
      </div>

      <!-- Apps sub-panel -->
      <div id="work-apps" class="work-subpanel space-y-8 hidden">
        <!-- CertPlatform project -->
        <article class="rounded-2xl bg-[#141417] border border-zinc-800/60 p-5 sm:p-8 transition-all duration-300 hover:border-zinc-700/80">
          <p class="text-xs font-mono uppercase tracking-widest text-accent">Certificate Management Platform</p>
          <h3 class="mt-3 sm:mt-4 text-xl sm:text-2xl font-semibold tracking-tight text-white">CertPlatform — web app for generating professional certificates.</h3>
          <div class="mt-4 sm:mt-6 grid gap-4 text-zinc-400 sm:grid-cols-3">
            <div>
              <p class="font-semibold text-white">Our goal</p>
              <p class="mt-2 text-sm sm:text-base">Build a streamlined platform that enables organizations to design, manage, and distribute certificates for trainees and clients with minimal effort.</p>
            </div>
            <div>
              <p class="font-semibold text-white">Our solution</p>
              <p class="mt-2 text-sm sm:text-base">We developed a full-featured web application with custom template creation, bulk certificate generation, and an analytics dashboard to track issuance data at a glance.</p>
            </div>
            <div>
              <p class="font-semibold text-white">Result</p>
              <p class="mt-2 text-sm sm:text-base">A fast, intuitive tool that eliminates manual certificate workflows — letting teams produce branded certificates in bulk with just a few clicks.</p>
            </div>
          </div>
          <div class="mt-4 flex flex-wrap gap-2">
            <span class="rounded-full border border-zinc-700/60 bg-zinc-800/20 px-3 py-1 text-xs text-zinc-400">Web Application</span>
            <span class="rounded-full border border-zinc-700/60 bg-zinc-800/20 px-3 py-1 text-xs text-zinc-400">Template Engine</span>
            <span class="rounded-full border border-zinc-700/60 bg-zinc-800/20 px-3 py-1 text-xs text-zinc-400">Analytics</span>
            <span class="rounded-full border border-zinc-700/60 bg-zinc-800/20 px-3 py-1 text-xs text-zinc-400">Bulk Generation</span>
          </div>
          <figure class="mt-6 sm:mt-8">
            <div class="relative mx-auto max-w-3xl overflow-hidden rounded-xl border border-zinc-800/60 bg-[#0b0b0e] shadow-[0_32px_80px_rgba(0,0,0,0.5)]">
              <div class="flex items-center gap-2 border-b border-zinc-800/60 bg-[#141417] px-4 py-2.5">
                <span class="h-2.5 w-2.5 rounded-full bg-zinc-700"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-zinc-700"></span>
                <span class="h-2.5 w-2.5 rounded-full bg-zinc-700"></span>
                <span class="ml-3 text-[10px] text-zinc-500">CertPlatform</span>
              </div>
              <img src="/assets/App%20pictures/Screenshot%202026-05-30%20224212.png" alt="CertPlatform dashboard" class="h-full w-full object-cover" loading="lazy" decoding="async" />
            </div>
          </figure>
        </article>
      </div>
    </div>

    <!-- TAB: SERVICES -->
    <div id="panel-services" class="tab-panel space-y-12 pb-12 hidden is-active">

      <!-- Website Development Packages -->
      <section class="space-y-8">
        <div class="space-y-4">
          <p class="text-xs font-mono uppercase tracking-widest text-zinc-500">[ / WEB DEVELOPMENT]</p>
          <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">Website development packages built for every stage of your business.</h2>
          <p class="max-w-3xl text-base leading-8 text-zinc-400">From a clean, high-converting brochure site to a fully dynamic platform with admin control — choose the tier that matches your ambition.</p>
        </div>

        <div class="grid gap-6 lg:grid-cols-3">
          <!-- TIER 1 -->
          <article class="rounded-2xl bg-[#141417] border border-zinc-800/60 p-6 sm:p-8 transition-all duration-300 hover:border-zinc-700/80 group flex flex-col">
            <div class="flex items-center justify-between mb-1">
              <p class="text-xs font-mono uppercase tracking-widest text-zinc-500">Tier 1</p>
              <span class="rounded-full bg-zinc-800/40 px-3 py-1 text-[10px] uppercase tracking-widest text-zinc-500">Essential</span>
            </div>
            <h3 class="text-xl sm:text-2xl font-semibold tracking-tight text-white">Simple Website</h3>
            <p class="mt-2 text-sm text-zinc-400">Establish a premium, high-converting digital presence.</p>
            <div class="mt-4 flex items-baseline gap-2">
              <span class="text-3xl font-semibold text-white">20,000 ETB</span>
            </div>
            <p class="text-xs text-zinc-500 mt-1">Timeline: 7 to 10 Days</p>
            <ul class="mt-6 space-y-2.5 flex-1">
              <li class="flex items-start gap-3 text-sm text-zinc-300"><span class="mt-0.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span>Custom website designs</li>
              <li class="flex items-start gap-3 text-sm text-zinc-300"><span class="mt-0.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span>Fully responsive UI for desktop, tablet, and mobile</li>
              <li class="flex items-start gap-3 text-sm text-zinc-300"><span class="mt-0.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span>Basic SEO configuration</li>
              <li class="flex items-start gap-3 text-sm text-zinc-300"><span class="mt-0.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span>Basic back-end setup and contact handling</li>
              <li class="flex items-start gap-3 text-sm text-zinc-300"><span class="mt-0.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span>Includes 3 to 6 months of free maintenance</li>
            </ul>
            <button data-tab-target="contact" class="mt-8 inline-flex w-full items-center justify-center rounded-full border border-zinc-700 bg-[#111113] px-6 py-3 text-sm font-semibold text-zinc-200 transition-all duration-300 ease-out hover:border-zinc-600 hover:text-white">Get Started</button>
          </article>

          <!-- TIER 2 -->
          <article class="rounded-2xl bg-[#141417] border border-accent/40 p-6 sm:p-8 shadow-[0_0_60px_rgba(0,179,126,0.08)] transition-all duration-300 hover:border-accent/60 group relative overflow-hidden flex flex-col">
