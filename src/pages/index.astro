---
import Layout from '../layouts/Layout.astro';
const canonical = 'https://yourdomain.com';
---
<Layout title="Conversion-Focused Portfolio Websites for Growing Brands" description="Strategy, design, and fast development for service businesses that need a sharper website and better inbound leads." canonical={canonical}>
  <section id="hero" class="showcase-hero pb-10 pt-6 sm:pb-16 sm:pt-10">
    <div class="grid gap-6 sm:gap-10 lg:grid-cols-[0.9fr_1.1fr] lg:items-start">
      <div class="hero-copy">
        <p class="text-xs font-mono uppercase tracking-widest text-zinc-500">[01 / STRATEGY + WEB DESIGN]</p>
        <h1 class="mt-4 sm:mt-5 max-w-3xl text-3xl font-semibold tracking-tight leading-[1.06] text-white sm:text-5xl lg:text-5xl xl:text-[4.35rem]">Premium websites that make your business easier to trust and easier to buy from.</h1>
        <p class="mt-4 sm:mt-5 max-w-2xl text-sm sm:text-lg tracking-tight text-zinc-300">We turn unclear offers into polished, fast-loading websites with focused messaging, confident visuals, and a clear path from first visit to inquiry.</p>
        <div class="mt-5 sm:mt-8 flex flex-col gap-3 sm:gap-4 sm:flex-row">
          <a href="#audit" class="inline-flex items-center justify-center rounded-full bg-accent px-5 py-3 sm:px-8 sm:py-4 text-sm sm:text-base font-semibold text-black shadow-[0_0_0_rgba(0,179,126,0.35)] transition-all duration-300 ease-out hover:shadow-[0_0_40px_rgba(0,179,126,0.28)]">Request a Website Review</a>
          <a href="#services" class="inline-flex items-center justify-center rounded-full border border-zinc-700 bg-[#111113] px-5 py-3 sm:px-8 sm:py-4 text-sm sm:text-base font-semibold text-zinc-200 transition-all duration-300 ease-out hover:border-zinc-600 hover:text-white">View Packages</a>
        </div>

        <div class="mt-5 sm:mt-8 max-w-xl rounded-[2rem] border border-zinc-800/60 bg-[#141417] p-4 sm:p-5 shadow-soft">
          <article class="grid gap-3 sm:gap-4">
            <div class="flex flex-col gap-2 sm:gap-3 sm:flex-row sm:items-center sm:justify-between">
              <span class="rounded-full bg-accent/10 px-3 py-1 text-xs uppercase tracking-[0.32em] text-accent">Built to convert</span>
              <p class="text-xs sm:text-sm text-zinc-400">Strategy, copy direction, design, development, and launch support.</p>
            </div>
            <div class="grid gap-3 sm:gap-4 sm:grid-cols-3">
              <div class="rounded-3xl bg-[#0f0f12] p-4 sm:p-5 text-center">
                <span class="block text-xs sm:text-sm uppercase tracking-[0.28em] text-zinc-500">Speed</span>
                <strong class="mt-2 sm:mt-3 block text-2xl sm:text-3xl font-semibold text-white">Fast</strong>
              </div>
              <div class="rounded-3xl bg-[#0f0f12] p-4 sm:p-5 text-center">
                <span class="block text-xs sm:text-sm uppercase tracking-[0.28em] text-zinc-500">Copy</span>
                <strong class="mt-2 sm:mt-3 block text-2xl sm:text-3xl font-semibold text-white">Clear</strong>
              </div>
              <div class="rounded-3xl bg-[#0f0f12] p-4 sm:p-5 text-center">
                <span class="block text-xs sm:text-sm uppercase tracking-[0.28em] text-zinc-500">SEO</span>
                <strong class="mt-2 sm:mt-3 block text-2xl sm:text-3xl font-semibold text-white">Ready</strong>
              </div>
            </div>
          </article>
        </div>
      </div>

      <div class="hero-visual" aria-label="Interactive 3D mobile website preview">
        <div class="iphone-scene" data-iphone-scene data-model-src="/assets/models/iphone.gltf">
          <canvas aria-hidden="true"></canvas>
          <div class="iphone-fallback">
            <div class="fallback-phone">
              <span></span>
              <strong>1.8s</strong>
              <p>Fast, clear, and ready.</p>
            </div>
          </div>
        </div>
        <div class="hero-visual-caption">
          <span>Interactive preview</span>
          <strong>Designed for the people deciding on mobile first</strong>
        </div>
      </div>
    </div>
  </section>

  <section id="work" class="space-y-8 sm:space-y-12 pb-16 sm:pb-20">
    <div class="grid gap-6 lg:grid-cols-[0.85fr_1.15fr] lg:items-end">
      <div class="space-y-3 sm:space-y-4">
        <p class="text-xs font-mono uppercase tracking-widest text-zinc-500">[02 / POSITIONING]</p>
        <h2 class="text-2xl sm:text-3xl font-semibold tracking-tight text-white sm:text-4xl">Most websites do not lose people because they look bad. They lose people because the value is hard to understand.</h2>
      </div>
        <p class="max-w-3xl text-sm sm:text-base leading-6 sm:leading-8 text-zinc-400">A strong site should answer the buyer's first questions quickly: what you do, why it matters, who it is for, and what happens next. We organize your content around those decisions so the experience feels polished, deliberate, and credible.</p>
    </div>

    <div class="grid gap-4 sm:gap-6 lg:grid-cols-3">
      <article class="rounded-2xl bg-[#141417] border border-zinc-800/60 p-5 sm:p-8 transition-all duration-300 hover:border-zinc-700/80">
        <p class="text-xs font-mono uppercase tracking-widest text-zinc-500">Message</p>
        <h3 class="mt-3 sm:mt-4 text-xl sm:text-2xl font-semibold tracking-tight text-white">Clarify the offer.</h3>
        <p class="mt-3 sm:mt-4 text-sm sm:text-base text-zinc-400">We refine the headline, proof points, service framing, and calls to action so visitors know exactly why they should care.</p>
      </article>
      <article class="rounded-2xl bg-[#141417] border border-zinc-800/60 p-5 sm:p-8 transition-all duration-300 hover:border-zinc-700/80">
        <p class="text-xs font-mono uppercase tracking-widest text-zinc-500">Experience</p>
        <h3 class="mt-3 sm:mt-4 text-xl sm:text-2xl font-semibold tracking-tight text-white">Guide the journey.</h3>
        <p class="mt-3 sm:mt-4 text-sm sm:text-base text-zinc-400">Each section earns its place, from the first impression to services, proof, pricing, and the final inquiry path.</p>
      </article>
      <article class="rounded-2xl bg-[#141417] border border-zinc-800/60 p-5 sm:p-8 transition-all duration-300 hover:border-zinc-700/80">
        <p class="text-xs font-mono uppercase tracking-widest text-zinc-500">Performance</p>
        <h3 class="mt-3 sm:mt-4 text-xl sm:text-2xl font-semibold tracking-tight text-white">Launch with confidence.</h3>
        <p class="mt-3 sm:mt-4 text-sm sm:text-base text-zinc-400">The site is built to feel quick, stable, responsive, and easy to maintain after the first version goes live.</p>
      </article>
    </div>
  </section>

  <section class="space-y-8 sm:space-y-10 pb-16 sm:pb-20">
    <div class="grid gap-6 lg:grid-cols-[0.9fr_1fr] lg:items-end">
      <div class="space-y-3 sm:space-y-4">
        <p class="text-xs font-mono uppercase tracking-widest text-zinc-500">[03 / SELECTED WORK]</p>
        <h2 class="text-2xl sm:text-3xl font-semibold tracking-tight text-white sm:text-4xl">Digital experiences shaped around trust, clarity, and conversion.</h2>
      </div>
      <p class="max-w-3xl text-sm sm:text-base leading-6 sm:leading-8 text-zinc-400">These concepts show the type of direction we bring to client projects: focused messaging, premium visual systems, and product previews that help people understand the offer faster.</p>
    </div>

    <div class="grid grid-cols-1 gap-4 sm:gap-6 md:grid-cols-3">
      <article class="md:col-span-2 rounded-2xl bg-[#141417] border border-zinc-800/60 p-5 sm:p-8 transition-all duration-300 hover:border-zinc-700/80">
        <p class="text-xs font-mono uppercase tracking-widest text-zinc-500">SaaS Interface</p>
        <h3 class="mt-3 sm:mt-4 text-xl sm:text-2xl font-semibold tracking-tight text-white">Nova Flow dashboard system.</h3>
        <div class="mt-4 sm:mt-6 grid gap-4 text-zinc-400 sm:grid-cols-3">
          <div>
            <p class="font-semibold text-white">Goal</p>
            <p class="mt-2 text-sm sm:text-base">Make a technical product feel organized, modern, and easy to evaluate.</p>
          </div>
          <div>
            <p class="font-semibold text-white">Approach</p>
            <p class="mt-2 text-sm sm:text-base">A clean desktop and mobile preview with strong contrast and quick scanning.</p>
          </div>
          <div>
            <p class="font-semibold text-white">Result</p>
            <p class="mt-2 text-sm sm:text-base">A sharper first impression for buyers comparing tools under time pressure.</p>
          </div>
        </div>
        <figure class="mt-6 sm:mt-8 overflow-hidden rounded-3xl border border-zinc-800/60 bg-[#0b0b0e]">
          <img src="/case-study-1.svg" alt="Nova Flow dashboard preview with desktop and mobile interface panels" class="aspect-[16/9] w-full object-cover" loading="lazy" />
        </figure>
      </article>

      <article class="rounded-2xl bg-[#141417] border border-zinc-800/60 p-5 sm:p-8 transition-all duration-300 hover:border-zinc-700/80">
        <p class="text-xs font-mono uppercase tracking-widest text-zinc-500">Launch Page</p>
        <h3 class="mt-3 sm:mt-4 text-xl sm:text-2xl font-semibold tracking-tight text-white">A focused software offer.</h3>
        <p class="mt-4 sm:mt-6 text-sm sm:text-base text-zinc-400">A compact campaign page that explains the product, frames the value, and moves visitors toward one primary action.</p>
        <figure class="mt-6 sm:mt-8 overflow-hidden rounded-3xl border border-zinc-800/60 bg-[#0b0b0e]">
          <img src="/case-study-3.svg" alt="Visual outline of a premium productized service offering" class="aspect-[4/3] w-full object-cover" loading="lazy" />
        </figure>
      </article>

      <article class="md:col-span-3 rounded-2xl bg-[#141417] border border-zinc-800/60 p-5 sm:p-8 transition-all duration-300 hover:border-zinc-700/80">
        <div class="grid gap-6 lg:grid-cols-[0.78fr_1.22fr] lg:items-center">
          <div>
            <p class="text-xs font-mono uppercase tracking-widest text-zinc-500">Premium Commerce</p>
            <h3 class="mt-3 sm:mt-4 text-xl sm:text-2xl font-semibold tracking-tight text-white">AETHER audio product experience.</h3>
            <div class="mt-4 sm:mt-6 space-y-4 text-zinc-400">
              <div>
                <p class="font-semibold text-white">Brand direction</p>
                <p class="mt-2 text-sm sm:text-base">A refined interface for high-end audio equipment, built to communicate craft, restraint, and confidence.</p>
              </div>
              <div>
                <p class="font-semibold text-white">Buyer experience</p>
                <p class="mt-2 text-sm sm:text-base">Immersive product presentation, clear hierarchy, and premium motion that supports the story without distracting from it.</p>
              </div>
            </div>
          </div>
          <div class="relative h-56 overflow-hidden rounded-3xl border border-zinc-800/60 bg-[#0b0b0e] sm:h-80 md:h-96">
            <div class="laptop-scene h-full w-full" data-laptop-scene data-model-src="/assets/models/laptop.glb">
              <canvas aria-hidden="true"></canvas>
            </div>
          </div>
        </div>
      </article>
    </div>
  </section>

  <section id="services" class="space-y-10 pb-20">
    <div class="grid gap-6 lg:grid-cols-[0.9fr_1fr] lg:items-end">
      <div class="space-y-4">
        <p class="text-xs font-mono uppercase tracking-widest text-zinc-500">[04 / SERVICES]</p>
        <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">Website packages built around the level of momentum you need.</h2>
      </div>
      <p class="max-w-3xl text-base leading-8 text-zinc-400">Every package includes strategy, design direction, responsive development, performance-minded implementation, and a launch handoff that keeps the site usable after delivery.</p>
    </div>

    <div class="grid gap-6 lg:grid-cols-3">
      <article class="rounded-2xl bg-[#141417] border border-zinc-800/60 p-8 transition-all duration-300 hover:border-zinc-700/80">
        <p class="text-xs font-mono uppercase tracking-widest text-zinc-500">Starter</p>
        <h3 class="mt-4 text-2xl font-semibold tracking-tight text-white">Landing Page Sprint</h3>
        <p class="mt-4 text-zinc-400">A focused single-page site for one offer, one audience, and one clear conversion path.</p>
        <div class="mt-6 space-y-3 text-white">
          <p class="text-3xl font-semibold">$4,500</p>
          <p class="text-sm text-zinc-500">Best for validating a service, campaign, or productized offer.</p>
        </div>
        <a href="#audit" class="mt-8 inline-flex w-full items-center justify-center rounded-full bg-accent px-6 py-3 text-sm font-semibold text-black transition-all duration-300 ease-out hover:shadow-[0_0_40px_rgba(0,179,126,0.2)]">Request this package</a>
      </article>

      <article class="rounded-2xl bg-[#141417] border border-accent/40 p-8 shadow-[0_0_60px_rgba(0,179,126,0.08)] transition-all duration-300 hover:border-accent/60">
        <p class="text-xs font-mono uppercase tracking-widest text-accent">Most requested</p>
        <h3 class="mt-4 text-2xl font-semibold tracking-tight text-white">Business Website Build</h3>
        <p class="mt-4 text-zinc-400">A polished multi-section or multi-page site for businesses that need stronger trust, service clarity, and lead quality.</p>
        <div class="mt-6 space-y-3 text-white">
          <p class="text-3xl font-semibold">$9,500</p>
          <p class="text-sm text-zinc-500">Best for established service brands ready to upgrade their digital presence.</p>
        </div>
        <a href="#audit" class="mt-8 inline-flex w-full items-center justify-center rounded-full bg-accent px-6 py-3 text-sm font-semibold text-black transition-all duration-300 ease-out hover:shadow-[0_0_40px_rgba(0,179,126,0.2)]">Start a project</a>
      </article>

      <article class="rounded-2xl bg-[#141417] border border-zinc-800/60 p-8 transition-all duration-300 hover:border-zinc-700/80">
        <p class="text-xs font-mono uppercase tracking-widest text-zinc-500">Growth</p>
        <h3 class="mt-4 text-2xl font-semibold tracking-tight text-white">Conversion Growth Suite</h3>
        <p class="mt-4 text-zinc-400">A website build plus ongoing improvements for brands that want to keep refining the customer journey after launch.</p>
        <div class="mt-6 space-y-3 text-white">
          <p class="text-3xl font-semibold">$14,500</p>
          <p class="text-sm text-zinc-500">Best for teams that need a sharper site and a plan for iteration.</p>
        </div>
        <a href="#audit" class="mt-8 inline-flex w-full items-center justify-center rounded-full bg-accent px-6 py-3 text-sm font-semibold text-black transition-all duration-300 ease-out hover:shadow-[0_0_40px_rgba(0,179,126,0.2)]">Discuss the suite</a>
      </article>
    </div>
  </section>

  <section class="space-y-8 pb-20">
    <div class="space-y-4">
      <p class="text-xs font-mono uppercase tracking-widest text-zinc-500">[05 / PROCESS]</p>
      <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">A straightforward process with fewer surprises.</h2>
    </div>
    <div class="grid gap-4 sm:gap-6 md:grid-cols-4">
      <article class="rounded-2xl bg-[#141417] border border-zinc-800/60 p-5 sm:p-6">
        <p class="text-xs font-mono uppercase tracking-widest text-zinc-500">01</p>
        <h3 class="mt-4 text-lg font-semibold text-white">Audit</h3>
        <p class="mt-3 text-sm text-zinc-400">We review the current site, offer, audience, and friction points.</p>
      </article>
      <article class="rounded-2xl bg-[#141417] border border-zinc-800/60 p-5 sm:p-6">
        <p class="text-xs font-mono uppercase tracking-widest text-zinc-500">02</p>
        <h3 class="mt-4 text-lg font-semibold text-white">Position</h3>
        <p class="mt-3 text-sm text-zinc-400">We define the page structure, messaging priorities, and conversion path.</p>
      </article>
      <article class="rounded-2xl bg-[#141417] border border-zinc-800/60 p-5 sm:p-6">
        <p class="text-xs font-mono uppercase tracking-widest text-zinc-500">03</p>
        <h3 class="mt-4 text-lg font-semibold text-white">Build</h3>
        <p class="mt-3 text-sm text-zinc-400">We design and develop a responsive experience with performance in mind.</p>
      </article>
      <article class="rounded-2xl bg-[#141417] border border-zinc-800/60 p-5 sm:p-6">
        <p class="text-xs font-mono uppercase tracking-widest text-zinc-500">04</p>
        <h3 class="mt-4 text-lg font-semibold text-white">Launch</h3>
        <p class="mt-3 text-sm text-zinc-400">We prepare the final site, review the details, and hand it over cleanly.</p>
      </article>
    </div>
  </section>

  <section id="audit" class="pb-20">
    <div class="grid gap-6 lg:grid-cols-[0.95fr_1.05fr] lg:items-start">
      <div class="space-y-4">
        <p class="text-xs font-mono uppercase tracking-widest text-zinc-500">[06 / WEBSITE REVIEW]</p>
        <h2 class="text-3xl font-semibold tracking-tight text-white sm:text-4xl">Want a clearer view of what your site is leaving on the table?</h2>
        <p class="max-w-3xl text-base leading-8 text-zinc-400">Send your current website and a short note about your business. We will identify the biggest clarity, trust, and conversion opportunities before recommending a package.</p>
      </div>

      <div class="rounded-[2rem] border border-zinc-800/60 bg-[#141417] p-8 shadow-soft">
        <form class="grid gap-6">
          <label class="block text-sm font-semibold tracking-tight text-zinc-100">
            Name
            <input type="text" name="name" required class="mt-3 w-full rounded-3xl border border-zinc-800/60 bg-[#0d0d11] px-5 py-4 text-sm text-zinc-100 outline-none transition-all duration-300 focus:border-accent/70 focus:ring-2 focus:ring-accent/10" />
          </label>
          <label class="block text-sm font-semibold tracking-tight text-zinc-100">
            Business email
            <input type="email" name="email" required class="mt-3 w-full rounded-3xl border border-zinc-800/60 bg-[#0d0d11] px-5 py-4 text-sm text-zinc-100 outline-none transition-all duration-300 focus:border-accent/70 focus:ring-2 focus:ring-accent/10" />
          </label>
          <label class="block text-sm font-semibold tracking-tight text-zinc-100">
            Current website URL
            <input type="url" name="website" required placeholder="https://" class="mt-3 w-full rounded-3xl border border-zinc-800/60 bg-[#0d0d11] px-5 py-4 text-sm text-zinc-100 outline-none transition-all duration-300 focus:border-accent/70 focus:ring-2 focus:ring-accent/10" />
          </label>
          <label class="block text-sm font-semibold tracking-tight text-zinc-100">
            What should the website help you achieve?
            <textarea name="brief" rows="5" required class="mt-3 w-full rounded-3xl border border-zinc-800/60 bg-[#0d0d11] px-5 py-4 text-sm text-zinc-100 outline-none transition-all duration-300 focus:border-accent/70 focus:ring-2 focus:ring-accent/10"></textarea>
          </label>
          <button type="submit" class="inline-flex w-full items-center justify-center rounded-full bg-accent px-6 py-4 text-base font-semibold text-black transition-all duration-300 ease-out hover:shadow-[0_0_40px_rgba(0,179,126,0.2)]">Request my website review</button>
        </form>
      </div>
    </div>
  </section>
</Layout>

<script>
  import * as THREE from 'three';
  import { RoomEnvironment } from 'three/examples/jsm/environments/RoomEnvironment.js';
  import { GLTFLoader } from 'three/examples/jsm/loaders/GLTFLoader.js';

  const sceneRoots = document.querySelectorAll<HTMLElement>('[data-iphone-scene]');

  sceneRoots.forEach((root) => {
    const canvas = root.querySelector('canvas');
    const modelSrc = root.dataset.modelSrc;

    if (!canvas || !modelSrc) {
      return;
    }

    const scene = new THREE.Scene();
    const camera = new THREE.PerspectiveCamera(34, 1, 0.1, 100);
    const renderer = new THREE.WebGLRenderer({
      canvas,
      alpha: true,
      antialias: true,
      powerPreference: 'high-performance'
    });

    renderer.outputColorSpace = THREE.SRGBColorSpace;
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 1.08;
    renderer.shadowMap.enabled = true;
    renderer.shadowMap.type = THREE.PCFSoftShadowMap;
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2.5));

    const makeScreenTexture = (source: HTMLImageElement) => {
      const safeTop = Math.round(source.height * 0.04);
      const screenScale = 1.08;
      const canvasTexture = document.createElement('canvas');
      canvasTexture.width = source.width;
      canvasTexture.height = source.height;

      const context = canvasTexture.getContext('2d');

      if (context) {
        const scaledWidth = source.width * screenScale;
        const scaledHeight = source.height * screenScale;
        const offsetX = (source.width - scaledWidth) / 2;

        context.fillStyle = '#031719';
        context.fillRect(0, 0, canvasTexture.width, canvasTexture.height);
        context.drawImage(source, offsetX, safeTop, scaledWidth, scaledHeight);
      }

      const texture = new THREE.CanvasTexture(canvasTexture);
      texture.colorSpace = THREE.SRGBColorSpace;
      texture.flipY = false;
      texture.minFilter = THREE.LinearFilter;
      texture.magFilter = THREE.LinearFilter;
      texture.generateMipmaps = false;
      texture.wrapS = THREE.RepeatWrapping;
      texture.center.set(0.5, 0.5);
      texture.rotation = Math.PI;
      texture.repeat.x = -1;
      texture.anisotropy = renderer.capabilities.getMaxAnisotropy();

      return texture;
    };

    const screenImage = new Image();
    screenImage.src = '/assets/pictures/novaflow-screen.png';
    const screenVideo = document.createElement('video');
    screenVideo.src = '/assets/videos/novaflow-scroll.webm';
    screenVideo.muted = true;
    screenVideo.loop = true;
    screenVideo.playsInline = true;
    screenVideo.preload = 'auto';
    const screenMaterial = new THREE.MeshBasicMaterial({
      color: 0xffffff,
      side: THREE.DoubleSide,
      toneMapped: false
    });
    const bodyMaterial = new THREE.MeshStandardMaterial({
      color: 0x191d20,
      metalness: 0.92,
      roughness: 0.24,
      envMapIntensity: 0.9
    });
    const backMaterial = new THREE.MeshStandardMaterial({
      color: 0x101316,
      metalness: 0.72,
      roughness: 0.34,
      envMapIntensity: 0.72
    });
    const blackGlassMaterial = new THREE.MeshBasicMaterial({
      color: 0x020305,
      side: THREE.DoubleSide,
      toneMapped: false
    });

    let videoTexture: THREE.VideoTexture | null = null;

    screenImage.addEventListener('load', () => {
      if (videoTexture) {
        return;
      }

      const fallbackTexture = makeScreenTexture(screenImage);
      screenMaterial.map?.dispose();
      screenMaterial.map = fallbackTexture;
      screenMaterial.needsUpdate = true;
    });

    const applyVideoTexture = () => {
      videoTexture = new THREE.VideoTexture(screenVideo);
      videoTexture.colorSpace = THREE.SRGBColorSpace;
      videoTexture.flipY = false;
      videoTexture.minFilter = THREE.LinearFilter;
      videoTexture.magFilter = THREE.LinearFilter;
      videoTexture.generateMipmaps = false;
      videoTexture.wrapS = THREE.RepeatWrapping;
      videoTexture.center.set(0.5, 0.5);
      videoTexture.rotation = Math.PI;
      videoTexture.repeat.x = -1;
      videoTexture.anisotropy = renderer.capabilities.getMaxAnisotropy();

      screenMaterial.map?.dispose();
      screenMaterial.map = videoTexture;
      screenMaterial.needsUpdate = true;
    };

      const ambientLight = new THREE.AmbientLight(0x404060, 0.6);
      scene.add(ambientLight);

      const keyLight = new THREE.DirectionalLight(0xffeedd, 8);
      keyLight.position.set(-3.5, 8, 4);
