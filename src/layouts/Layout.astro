---
import '../styles/global.css';

const {
  title = 'High-Performance Web Architecture for Premium B2B Brands',
  description = 'Built for fast conversions, enterprise-grade security, and elevated brand credibility with semantic SEO and premium digital design.',
  canonical = 'https://yourdomain.com'
} = Astro.props;
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Premium Web Architecture',
  url: canonical,
  logo: 'https://yourdomain.com/logo.svg',
  sameAs: ['https://www.linkedin.com/in/yourprofile'],
  contactPoint: [{
    '@type': 'ContactPoint',
    contactType: 'business',
    email: 'hello@yourdomain.com'
  }]
};
---
<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#09090b" />
    <meta name="color-scheme" content="dark" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <title>{title}</title>
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="/og-image.svg" />
    <script type="application/ld+json">{JSON.stringify(organizationSchema)}</script>
  </head>
  <body class="min-h-screen bg-[#09090b] text-zinc-100 selection:bg-accent/30 antialiased">
    <div class="min-h-screen bg-[radial-gradient(circle_at_top_left,_rgba(0,179,126,0.10),_transparent_28%)] bg-grid">
      <header class="fixed inset-x-0 top-6 z-50 flex justify-center px-4">
        <nav class="w-full max-w-6xl bg-zinc-950/50 backdrop-blur-xl border border-zinc-800/40 rounded-full px-6 py-3 shadow-soft">
          <div class="flex flex-col gap-3 text-sm text-zinc-300 sm:flex-row sm:items-center sm:justify-between">
            <a class="font-semibold uppercase tracking-[0.28em] text-zinc-300" href="#hero">ARCHITECTURE</a>
            <div class="flex flex-wrap items-center gap-4 text-zinc-400">
              <a class="transition-all duration-300 ease-out hover:text-white" href="#work">Work</a>
              <a class="transition-all duration-300 ease-out hover:text-white" href="#services">Services</a>
              <a class="transition-all duration-300 ease-out hover:text-white" href="#audit">Audit</a>
            </div>
            <a class="inline-flex items-center justify-center rounded-full border border-accent/30 bg-accent/10 px-4 py-2 text-xs uppercase tracking-[0.32em] text-accent transition-all duration-300 hover:bg-accent/15 hover:text-white" href="#audit">Free Audit</a>
          </div>
        </nav>
      </header>

      <main class="relative pt-28">
        <div class="mx-auto w-full max-w-7xl px-4 sm:px-6">
          <slot />
        </div>
      </main>

      <footer class="border-t border-zinc-800/60 bg-[#09090b]/90 py-8">
        <div class="mx-auto max-w-6xl px-4 sm:px-6">
          <p class="text-sm text-zinc-500">&copy; {new Date().getFullYear()} Premium Web Architecture. Built for speed, trust, and business growth.</p>
        </div>
      </footer>
    </div>
  </body>
</html>
