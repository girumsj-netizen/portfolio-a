---
import '../styles/global.css';

const {
  title = 'Premium Digital Studio — Websites, UI, and Brand Experiences',
  description = 'We craft high-performance websites, complex UI interactions, and bespoke digital experiences for modern brands.',
  canonical = 'https://yourdomain.com'
} = Astro.props;
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Nova Studio',
  url: canonical,
  logo: 'https://yourdomain.com/logo.svg',
  sameAs: ['https://www.linkedin.com/in/yourprofile'],
  contactPoint: [{
    '@type': 'ContactPoint',
    contactType: 'business',
    email: 'hello@yourdomain.com'
  }]
};
---
<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#09090b" />
    <meta name="color-scheme" content="dark" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <title>{title}</title>
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="/og-image.svg" />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
  </head>
  <body class="min-h-screen bg-[#09090b] text-zinc-100 selection:bg-accent/30 antialiased">
    <div class="min-h-screen bg-[radial-gradient(circle_at_top_left,_rgba(0,179,126,0.10),_transparent_28%)] bg-grid">
      <div class="ambient-particles" aria-hidden="true">
        <span style="--x: 8%; --y: 14%; --d: 0s; --s: 1; --t: 7s; --dx: 24px; --dy: -42px;"></span>
        <span style="--x: 18%; --y: 46%; --d: 1.8s; --s: 0.75; --t: 11s; --dx: -18px; --dy: -54px;"></span>
        <span style="--x: 31%; --y: 22%; --d: 3.2s; --s: 1.15; --t: 8.5s; --dx: 32px; --dy: -36px;"></span>
        <span style="--x: 44%; --y: 68%; --d: 0.8s; --s: 0.85; --t: 12s; --dx: -28px; --dy: -62px;"></span>
        <span style="--x: 57%; --y: 18%; --d: 4.4s; --s: 1; --t: 9s; --dx: 20px; --dy: -48px;"></span>
        <span style="--x: 71%; --y: 38%; --d: 2.6s; --s: 0.7; --t: 6.5s; --dx: -22px; --dy: -38px;"></span>
        <span style="--x: 84%; --y: 16%; --d: 5.1s; --s: 1.2; --t: 10s; --dx: 30px; --dy: -58px;"></span>
        <span style="--x: 91%; --y: 62%; --d: 1.2s; --s: 0.9; --t: 7.8s; --dx: -34px; --dy: -44px;"></span>
        <span class="particle-dense" style="--x: 7%; --y: 82%; --d: 0.4s; --s: 0.85; --t: 6.8s; --dx: 30px; --dy: -34px;"></span>
        <span class="particle-dense" style="--x: 15%; --y: 91%; --d: 1.6s; --s: 1.1; --t: 8.4s; --dx: -20px; --dy: -52px;"></span>
        <span class="particle-dense" style="--x: 24%; --y: 78%; --d: 2.5s; --s: 0.7; --t: 5.8s; --dx: 26px; --dy: -48px;"></span>
        <span class="particle-dense" style="--x: 34%; --y: 87%; --d: 3.1s; --s: 0.95; --t: 9.2s; --dx: -34px; --dy: -40px;"></span>
        <span class="particle-dense" style="--x: 43%; --y: 94%; --d: 0.9s; --s: 1.25; --t: 6.2s; --dx: 18px; --dy: -56px;"></span>
        <span class="particle-dense" style="--x: 51%; --y: 80%; --d: 4.7s; --s: 0.75; --t: 10.5s; --dx: -24px; --dy: -42px;"></span>
        <span class="particle-dense" style="--x: 62%; --y: 90%; --d: 2.2s; --s: 1; --t: 7.3s; --dx: 34px; --dy: -60px;"></span>
        <span class="particle-dense" style="--x: 70%; --y: 76%; --d: 5.5s; --s: 0.8; --t: 5.9s; --dx: -28px; --dy: -36px;"></span>
        <span class="particle-dense" style="--x: 82%; --y: 88%; --d: 3.8s; --s: 1.15; --t: 8.8s; --dx: 22px; --dy: -54px;"></span>
        <span class="particle-dense" style="--x: 93%; --y: 82%; --d: 1.1s; --s: 0.9; --t: 6.9s; --dx: -30px; --dy: -46px;"></span>
      </div>
      <header class="fixed inset-x-0 top-6 z-50 flex justify-center px-4">
        <nav class="w-full max-w-6xl bg-zinc-950/50 backdrop-blur-xl border border-zinc-800/40 rounded-full px-6 py-3 shadow-soft">
          <div class="flex flex-col gap-3 text-sm text-zinc-300 sm:flex-row sm:items-center sm:justify-between">
            <a class="font-semibold uppercase tracking-[0.28em] text-zinc-300" href="#hero">NOVA STUDIO</a>
            <div class="flex flex-wrap items-center gap-4 text-zinc-400">
              <a class="transition-all duration-300 ease-out hover:text-white" href="#work">Work</a>
              <a class="transition-all duration-300 ease-out hover:text-white" href="#services">Services</a>
              <a class="transition-all duration-300 ease-out hover:text-white" href="#process">Process</a>
              <a class="transition-all duration-300 ease-out hover:text-white" href="#contact">Contact</a>
            </div>
            <a class="inline-flex items-center justify-center rounded-full bg-accent px-5 py-2 text-xs uppercase tracking-[0.32em] font-semibold text-black transition-all duration-300 ease-out hover:shadow-[0_0_40px_rgba(0,179,126,0.28)]" href="#contact">Start a Project</a>
          </div>
        </nav>
      </header>

      <main class="relative pt-28">
        <div class="mx-auto w-full max-w-7xl px-4 sm:px-6">
          <slot />
        </div>
      </main>

      <footer class="digital-footer border-t border-zinc-800/60 bg-[#09090b]/90 py-8">
        <div class="mx-auto max-w-6xl px-4 sm:px-6">
          <p class="text-sm text-zinc-500">&copy; {new Date().getFullYear()} Nova Studio. We craft digital experiences that elevate brands and drive results.</p>
        </div>
      </footer>
    </div>
  </body>
</html>
